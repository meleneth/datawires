%div{ class: wrapper_class }
  - if show_label?
    .flex.items-center.justify-between.gap-3
      .flex.items-center.gap-1
        = render TypographyComponent.new(as: :h4, text: label_text)
        - if required?
          %span.text-sm.font-semibold.text-destructive *
      = render BadgeComponent.new(variant: :outline) do
        = item_count_text
    - if help_text.present?
      %p.text-xs.text-muted-foreground= help_text

  - if show_add_item_button?
    .flex.justify-end
      = button_to "Add item",
        add_item_path,
        method: :patch,
        params: add_item_button_params,
        data: { turbo_frame: "editor" },
        class: "font-head inline-flex h-8 items-center justify-center rounded border-2 border-black bg-secondary px-3 text-sm font-medium text-secondary-foreground shadow-md transition-all hover:translate-y-1 hover:shadow-none"

  - if inline_blank_form? && new_item_fields.any?
    .rounded.border-2.border-black.bg-card.p-3.shadow-sm
      .space-y-3
        = render TypographyComponent.new(as: :h4, text: "New item")
        .grid.grid-cols-1.gap-3
          - new_item_fields.each do |field|
            = render Drafts::ProjectedFieldComponent.new(draft: draft, field: field, edit_affordance_id: edit_affordance&.id)

  - if empty?
    = render AlertComponent.new do
      No items yet.
  - elsif table_presentation?
    .overflow-x-auto
      %table.min-w-full.text-sm
        %thead
          %tr.border-b-2.border-black
            %th.px-3.py-2.text-left.font-head Item
            %th.px-3.py-2.text-left.font-head Preview
            %th.px-3.py-2.text-right.font-head Action
        %tbody
          - item_links.each do |item_link|
            %tr.border-b.border-border
              %td.px-3.py-2.font-head.font-medium= item_link[:title]
              %td.px-3.py-2.text-muted-foreground= item_link[:value_label]
              %td.px-3.py-2.text-right
                .inline-flex.items-center.gap-2
                  = link_to item_link[:path],
                    data: { turbo_frame: "editor", turbo_action: "advance" },
                    class: "font-head inline-flex h-8 items-center justify-center rounded border-2 border-black bg-secondary px-3 text-sm font-medium text-secondary-foreground shadow-sm transition-all hover:translate-y-1 hover:shadow-none" do
                    Open
                  - if reorder_enabled? && !item_link[:first]
                    = button_to "Up",
                      reorder_item_path,
                      method: :patch,
                      params: item_link[:move_up_params],
                      data: { turbo_frame: "editor" },
                      class: "font-head inline-flex h-8 items-center justify-center rounded border-2 border-black bg-background px-3 text-sm font-medium text-foreground shadow-sm transition-all hover:translate-y-1 hover:shadow-none"
                  - if reorder_enabled? && !item_link[:last]
                    = button_to "Down",
                      reorder_item_path,
                      method: :patch,
                      params: item_link[:move_down_params],
                      data: { turbo_frame: "editor" },
                      class: "font-head inline-flex h-8 items-center justify-center rounded border-2 border-black bg-background px-3 text-sm font-medium text-foreground shadow-sm transition-all hover:translate-y-1 hover:shadow-none"
                  - if delete_enabled?
                    = button_to "Delete",
                      remove_item_path,
                      method: :patch,
                      params: item_link[:remove_params],
                      data: { turbo_frame: "editor" },
                      class: "font-head inline-flex h-8 items-center justify-center rounded border-2 border-black bg-destructive px-3 text-sm font-medium text-destructive-foreground shadow-sm transition-all hover:translate-y-1 hover:shadow-none"
  - elsif cards_presentation?
    .grid.grid-cols-1.gap-3.md:grid-cols-2
      - item_links.each do |item_link|
        .rounded.border-2.border-black.bg-card.p-3.text-card-foreground.shadow-sm
          .flex.items-start.justify-between.gap-3
            = link_to item_link[:path],
              data: { turbo_frame: "editor", turbo_action: "advance" },
              class: "min-w-0 flex-1 transition-all hover:translate-y-0.5" do
              .min-w-0
                .font-head.text-sm.font-medium= item_link[:title]
                .text-xs.text-muted-foreground= item_link[:value_label]
            .flex.shrink-0.items-center.gap-2
              = render BadgeComponent.new(variant: :secondary) do
                Open
              - if reorder_enabled? && !item_link[:first]
                = button_to "Up",
                  reorder_item_path,
                  method: :patch,
                  params: item_link[:move_up_params],
                  data: { turbo_frame: "editor" },
                  class: "font-head inline-flex h-8 items-center justify-center rounded border-2 border-black bg-background px-3 text-sm font-medium text-foreground shadow-sm transition-all hover:translate-y-1 hover:shadow-none"
              - if reorder_enabled? && !item_link[:last]
                = button_to "Down",
                  reorder_item_path,
                  method: :patch,
                  params: item_link[:move_down_params],
                  data: { turbo_frame: "editor" },
                  class: "font-head inline-flex h-8 items-center justify-center rounded border-2 border-black bg-background px-3 text-sm font-medium text-foreground shadow-sm transition-all hover:translate-y-1 hover:shadow-none"
              - if delete_enabled?
                = button_to "Delete",
                  remove_item_path,
                  method: :patch,
                  params: item_link[:remove_params],
                  data: { turbo_frame: "editor" },
                  class: "font-head inline-flex h-8 items-center justify-center rounded border-2 border-black bg-destructive px-3 text-sm font-medium text-destructive-foreground shadow-sm transition-all hover:translate-y-1 hover:shadow-none"
  - else
    .space-y-2
      - item_links.each do |item_link|
        .flex.items-center.justify-between.gap-3.rounded.border-2.border-black.bg-card.px-3.py-2.text-card-foreground.shadow-sm
          = link_to item_link[:path],
            data: { turbo_frame: "editor", turbo_action: "advance" },
            class: "min-w-0 flex-1 transition-all hover:translate-y-0.5" do
            .min-w-0
              .font-head.text-sm.font-medium= item_link[:title]
              .text-xs.text-muted-foreground= item_link[:value_label]
          .flex.shrink-0.items-center.gap-2
            = render BadgeComponent.new(variant: :secondary) do
              Open
            - if reorder_enabled? && !item_link[:first]
              = button_to "Up",
                reorder_item_path,
                method: :patch,
                params: item_link[:move_up_params],
                data: { turbo_frame: "editor" },
                class: "font-head inline-flex h-8 items-center justify-center rounded border-2 border-black bg-background px-3 text-sm font-medium text-foreground shadow-sm transition-all hover:translate-y-1 hover:shadow-none"
            - if reorder_enabled? && !item_link[:last]
              = button_to "Down",
                reorder_item_path,
                method: :patch,
                params: item_link[:move_down_params],
                data: { turbo_frame: "editor" },
                class: "font-head inline-flex h-8 items-center justify-center rounded border-2 border-black bg-background px-3 text-sm font-medium text-foreground shadow-sm transition-all hover:translate-y-1 hover:shadow-none"
            - if delete_enabled?
              = button_to "Delete",
                remove_item_path,
                method: :patch,
                params: item_link[:remove_params],
                data: { turbo_frame: "editor" },
                class: "font-head inline-flex h-8 items-center justify-center rounded border-2 border-black bg-destructive px-3 text-sm font-medium text-destructive-foreground shadow-sm transition-all hover:translate-y-1 hover:shadow-none"

.space-y-3
  - if show_label?
    .flex.items-center.justify-between.gap-3
      %h4.text-sm.font-medium.text-ink= label_text
      .text-xs.text-ls5-violet-5= item_count_text

  .flex.justify-end
    = button_to "Add item",
      add_item_path,
      method: :patch,
      params: add_item_button_params,
      data: { turbo_frame: "editor" },
      class: "rounded-lg px-3 py-2 text-sm font-medium text-ls5-blue-4 hover:bg-ls5-violet-1"

  - if empty?
    .rounded-lg.border.border-ls5-violet-2.p-4.text-sm.text-ls5-violet-6
      No items yet.
  - else
    .space-y-3
      - item_cards.each do |item_card|
        .rounded-lg.border.border-ls5-violet-2.p-3.space-y-3
          .text-sm.font-medium= item_card[:title]

          .grid.grid-cols-6.gap-3
            - item_card[:child_components].each do |child_component|
              %div.col-span-6
                = render child_component

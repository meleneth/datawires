= render CardComponent.new(html_options: { class: "w-full" }) do
  = render CardContentComponent.new do
    .space-y-4
      .space-y-1
        = render TypographyComponent.new(as: :muted, text: "Path")
        .font-mono.text-sm.text-foreground= path_label

      .flex.items-center.justify-between
        = render TypographyComponent.new(as: :h3, text: title)

        = render ButtonComponent.new(href: commit_path, size: :sm, html_options: { data: { turbo_frame: "main_content" } }) do
          Commit

      - if projected_rows?
        = render projected_rows_component
      - else
        = render AlertComponent.new do
          No edit affordance projection available for this location.

%div{ class: wrapper_class }
  - if show_label?
    .flex.items-center.gap-1
      = render LabelComponent.new(text: label_text, for_id: dom_id)
      - if required?
        %span.text-sm.font-semibold.text-destructive *

  - if readonly?
    .rounded.border-2.border-black.bg-muted.px-3.py-2.text-sm.text-muted-foreground{ id: dom_id }
      = value_preview
  - else
    = form_with url: patch_path, method: :patch, format: :turbo_stream, data: form_data_attributes do |form|
      = form.hidden_field :ptr, value: ptr
      = form.hidden_field :path, value: path
      = form.hidden_field :edit_affordance_id, value: edit_affordance_id if edit_affordance_id.present?

      = form.public_send(input_method, *input_leading_args)

  - if help_text.present?
    %p.text-xs.text-muted-foreground= help_text

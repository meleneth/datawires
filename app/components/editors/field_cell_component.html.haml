.space-y-1
  .flex.items-start.justify-between.gap-4
    .min-w-0.flex-1.space-y-1
      - if cell.label
        .flex.items-center.gap-1
          .font-medium.text-ink= row.name
          - if row.required? && !row.present?
            %span.text-ls5-red-5 *
      - if row.scalar?
        .pt-1
          = render Editors::DocumentScalarFieldComponent.new(row: row, widget: cell.widget, show_label: false, edit_affordance_id: edit_affordance_id, current_path: current_path)
      - elsif row.composite?
        .pt-1.text-xs.text-ls5-violet-5= row.value_label

    - if row.composite?
      = link_to "Open",
        open_path,
        data: { turbo_frame: "editor", turbo_action: "advance" },
        class: "rounded-lg px-3 py-2 text-sm font-medium text-ls5-blue-4 hover:bg-ls5-violet-1"

.flex.items-center.space-x-2
  = @form.text_field @name,
    id: @id,
    placeholder: @label,
    class: "w-48 px-3 py-2 rounded-md border border-ls5-yellow-6 bg-ls5-yellow-1 text-ink placeholder:text-ls5-yellow-7 focus:outline-none focus:ring-2 focus:ring-ls5-yellow-4 focus:border-ls5-yellow-5"

  = @form.submit @button_text,
    class: "px-3 py-2 rounded-md border border-ls5-red-7 bg-ls5-red-6 text-ink-inverse hover:bg-ls5-red-7 focus:outline-none focus:ring-2 focus:ring-ls5-red-4"

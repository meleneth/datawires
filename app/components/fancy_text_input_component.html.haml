.flex.items-center.space-x-2
  = @form.text_field @name,
    id: @id,
    placeholder: @label,
    class: "w-48 px-3 py-2 border rounded-md bg-yellow-200 text-gray-900 focus:outline-none focus:ring-2 focus:ring-yellow-400"

  = @form.submit @button_text,
    class: "px-3 py-2 border rounded-md bg-red-500 text-white hover:bg-red-700 focus:outline-none focus:ring-2 focus:ring-red-400"

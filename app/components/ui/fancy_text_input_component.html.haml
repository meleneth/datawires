.flex.items-center.space-x-2
  = @form.text_field @name,
    id: @id,
    placeholder: @label,
    class: "flex h-10 w-48 rounded border-2 border-black bg-background px-3 py-2 text-sm text-foreground shadow-sm transition-all placeholder:text-muted-foreground focus-visible:outline-hidden focus-visible:shadow-md"

  = @form.submit @button_text,
    class: "font-head inline-flex h-10 items-center justify-center rounded border-2 border-black bg-primary px-3 py-2 font-medium text-primary-foreground shadow-md transition-all hover:translate-y-1 hover:shadow-none"

%nav.schema-nav{ data: { turbo_prefetch: "false" } }
  - crumbs.each_with_index do |crumb, idx|
    - options = choices_for(crumb[:path])
    %span.schema-nav__group
      = link_to crumb[:label],
        nav_url(crumb[:path]),
        data: { turbo_frame: turbo_frame, turbo_action: "advance" },
        class: "schema-nav__crumb"
      - if options.any?
        %button.schema-nav__chev{
          type: "button",
          data: { action: "click->dropdown#toggle", dropdown_level_param: idx }
        }
          >
        %div.schema-nav__menu.hidden{ data: { dropdown_target: "menu", level: idx } }
          - options.each do |key|
            - target_path = child_path(crumb[:path], key)
            = link_to key, nav_url(target_path), data: { turbo_frame: turbo_frame, turbo_action: "advance", action: "click->dropdown#close" }, class: "schema-nav__item"
      - elsif idx < crumbs.length - 1
        %span.schema-nav__sep.schema-nav__sep--disabled
          >

%nav.relative.inline-flex.items-center.text-sm
  .group.relative
    %button{ type: "button",
             class: "inline-flex items-center gap-2 rounded-lg px-3 py-2 font-medium text-slate-200 hover:bg-slate-800/70 hover:text-white focus:outline-none focus-visible:ring-2 focus-visible:ring-sky-400" }
      = title

    %span.text-slate-400.group-hover:text-slate-200
      ▾

    - bridge_align_class = (panel_align_class.include?("right-0") ? "right-0" : "left-0")

    / Hover bridge: fills the mt-2 gap so hover doesn't break
    .absolute.top-full.h-2.pointer-events-auto{ class: "#{bridge_align_class} #{width_class}" }

    %div{ class: "invisible absolute top-full z-50 mt-2 rounded-xl border border-slate-700/60 bg-slate-900/95 p-1 text-slate-200 shadow-xl shadow-black/30 opacity-0 backdrop-blur transition
                 group-hover:visible group-hover:opacity-100 #{panel_align_class} #{width_class}" }
      - entries.each do |entry|
        = entry

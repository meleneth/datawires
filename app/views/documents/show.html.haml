= turbo_frame_tag "main_content" do
  %h1= @document.title.presence || @document.key

  %p
    %strong Domain:
    = @domain.name

  %p
    %strong Key:
    = @document.key

  - if @schema_document
    %p
      %strong Schema:
      = link_to @schema_document.key, schema_path(@schema_document)

  - if @edit_affordances.any?
    .mt-6
      %h2.text-lg.font-semibold Edit affordances

      %ul.mt-2.space-y-2
        - @edit_affordances.each do |affordance|
          %li
            = button_to document_draft_path(@document, edit_affordance_id: affordance.id),
              method: :post,
              class: "block w-full rounded-md border border-ls5-blue-1 px-3 py-2 text-left hover:bg-ls5-blue-1" do
              .font-medium= affordance.title
              .text-xs.text-ls5-violet-6= affordance.edit_document.key

  - if @view_affordances.any?
    .mt-6
      %h2.text-lg.font-semibold View affordances

      %ul.mt-2.space-y-2
        - @view_affordances.each do |view_affordance|
          %li.rounded-md.border.border-ls5-violet-2.px-3.py-2
            .font-medium= view_affordance.title
            .text-xs.text-ls5-violet-6= view_affordance.view_document.key

  .mt-6
    %pre
      = JSON.pretty_generate(@document.body)

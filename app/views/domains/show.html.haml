= turbo_frame_tag "main_content" do
  = render TypographyComponent.new(as: :h1, text: "#{@domain.name} Domain", html_options: { class: "mb-4" })

  = render CardComponent.new(html_options: { class: "w-full" }) do
    = render CardContentComponent.new do
      .space-y-6
        - if notice.present?
          = render AlertComponent.new do
            = notice

        .space-y-1
          = render TypographyComponent.new(as: :muted, text: "Name")
          .font-head.text-lg.font-medium.text-foreground= @domain.name

        .flex.flex-wrap.items-center.gap-3
          = render ButtonComponent.new(href: edit_domain_path(@domain), variant: :secondary, size: :sm) do
            Edit this domain
          = render ButtonComponent.new(href: domains_path, variant: :outline, size: :sm) do
            Back to domains
          = render ButtonComponent.new(href: domain_archive_path(@domain), variant: :outline, size: :sm) do
            Export archive
          = button_to "Destroy this domain", @domain, method: :delete, class: "font-head inline-flex h-8 items-center justify-center rounded border-2 border-black bg-destructive px-3 text-sm font-medium text-destructive-foreground shadow-md transition-all hover:translate-y-1 hover:shadow-none"

        .space-y-3
          = render TypographyComponent.new(as: :h3, text: "Add schema")

          = form_with model: [@domain, @document], url: domain_schemas_path(@domain), class: "space-y-4" do |f|
            .space-y-1
              = render LabelComponent.new(text: "New schema name", for_id: "document_key")
              = render InputComponent.new(name: f.field_name(:key), value: @document.key, html_options: { id: "document_key", autofocus: true })
              - if @document.errors[:key].any?
                %p.text-sm.text-destructive= @document.errors[:key].to_sentence
            = render ButtonComponent.new(html_options: { type: :submit }) do
              Create

  = render "domains/home_links"
  = render "domains/open_drafts"
  = render "domains/schemas"

= render TypographyComponent.new(as: :h2, text: "Open Drafts", html_options: { class: "mb-4 mt-6" })

= render CardComponent.new(html_options: { class: "w-full" }) do
  = render CardContentComponent.new do
    - if @drafts.any?
      %ul.space-y-2
        - @drafts.each do |draft|
          %li
            = link_to draft_path(draft), class: "flex items-center justify-between rounded border-2 border-black bg-card px-3 py-2 text-card-foreground shadow-sm transition-all hover:translate-y-1 hover:shadow-none" do
              .min-w-0
                .font-head.font-medium= draft.document.key
                .text-xs.text-muted-foreground
                  = "updated #{time_ago_in_words(draft.updated_at)} ago"
    - else
      = render TypographyComponent.new(as: :muted, text: "No drafts yet")

= render ThingCardComponent.new do |c|
  - c.with_label do
    Open Drafts

  - if @drafts.any?
    %ul.mt-2.space-y-1
      - @drafts.each do |draft|
        %li{class: "flex justify-between items-center bg-slate-800/60 rounded px-3 py-2"}
          = link_to draft.document.key,
            domain_document_draft_path(@domain, document_key: draft.document.key, id: draft.id),
            class: "text-sky-400 hover:text-sky-300 hover:underline font-medium"

          %span.text-slate-400.text-xs
            updated #{time_ago_in_words(draft.updated_at)} ago
  - else
    %p.text-slate-500.mt-2
      No drafts yet


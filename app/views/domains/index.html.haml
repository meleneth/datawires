- content_for :title, "Domains"

= render TypographyComponent.new(as: :h1, text: "Domains", html_options: { class: "mb-4" })

- if notice.present?
  .mb-4
    = render AlertComponent.new do
      = notice

= render CardComponent.new(html_options: { class: "w-full" }) do
  = render CardContentComponent.new do
    .space-y-4
      - if @domains.empty?
        = render TypographyComponent.new(as: :muted, text: "No domains yet.")

      %ul.space-y-2
        - @domains.each do |domain|
          %li
            = link_to domain, class: "flex items-center justify-between rounded border-2 border-black bg-card px-3 py-3 text-card-foreground shadow-sm transition-all hover:translate-y-1 hover:shadow-none" do
              .min-w-0
                .font-head.font-medium= domain.name
              .text-sm.text-muted-foreground= "Open"

      = render ButtonComponent.new(href: new_domain_path, size: :sm) do
        New domain

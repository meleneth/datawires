- content_for :title, "Domains"

= render PageHeaderComponent.new(text: "Domains")

- if notice.present?
  %p.mb-4.text-ls5-green-7= notice

= render CardComponent.new do
  - if @domains.empty?
    .text-ls5-violet-6 No domains yet.

  %ul.divide-y.divide-ls5-violet-2
    - @domains.each do |domain|
      %li
        = link_to domain, class: "flex items-center justify-between px-3 py-3 rounded-md hover:bg-ls5-violet-1 transition-colors" do
          .min-w-0
            .font-medium.text-ink= domain.name
          .text-ls5-violet-5.text-sm →
  
  .mt-4
    = link_to "New domain", new_domain_path, class: "inline-flex items-center rounded-lg border border-ls5-blue-5 bg-ls5-blue-4 px-3 py-2 text-sm font-medium text-ink-inverse hover:bg-ls5-blue-5"

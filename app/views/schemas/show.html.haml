= turbo_frame_tag "main_content" do
  = render TypographyComponent.new(as: :h1, text: "Schema", html_options: { class: "mb-4" })

  .mb-4.flex.gap-2
    = button_to "New document",
      schema_documents_path(@schema_wrapper),
      method: :post,
      form: { data: { turbo_frame: "main_content", turbo_action: "advance" } },
      class: "font-head inline-flex h-10 items-center justify-center rounded border-2 border-black bg-primary px-4 py-2 font-medium text-primary-foreground shadow-md transition-all hover:translate-y-1 hover:shadow-none"

    = button_to "Edit schema",
      document_draft_path(@schema_wrapper.document),
      method: :post,
      form: { data: { turbo_frame: "main_content", turbo_action: "advance" } },
      class: "font-head inline-flex h-10 items-center justify-center rounded border-2 border-black bg-secondary px-4 py-2 font-medium text-secondary-foreground shadow-md transition-all hover:translate-y-1 hover:shadow-none"

  = render CardComponent.new(html_options: { class: "w-full" }) do
    = render CardContentComponent.new do
      %dl.grid.gap-3.text-sm.md:grid-cols-2
        %div
          %dt.text-muted-foreground Domain
          %dd.font-head.text-foreground= @schema_wrapper.domain.name

        %div
          %dt.text-muted-foreground Key
          %dd.font-head.text-foreground= @schema_wrapper.key

  .mt-6
    .flex.items-center.justify-between.gap-3
      = render TypographyComponent.new(as: :h2, text: "Edit affordances")
      = button_to "New edit affordance",
        schema_edit_affordances_path(@schema_wrapper),
        method: :post,
        params: { title: "Default" },
        form: { data: { turbo_frame: "main_content", turbo_action: "advance" } },
        class: "font-head inline-flex h-8 items-center justify-center rounded border-2 border-black bg-secondary px-3 text-sm font-medium text-secondary-foreground shadow-md transition-all hover:translate-y-1 hover:shadow-none"

    - if @edit_affordances.any?
      %ul.mt-2.space-y-2
        - @edit_affordances.each do |affordance|
          %li.flex.items-center.justify-between.rounded.border-2.border-black.bg-card.px-3.py-2.text-card-foreground.shadow-sm
            .min-w-0
              .font-head.font-medium= affordance.title
              - if affordance.edit_document.present?
                .text-xs.text-muted-foreground= affordance.edit_document.title.presence || affordance.edit_document.key

            .flex.flex-wrap.justify-end.gap-2
              - affordance_draft = @edit_affordance_drafts[affordance.edit_document_id]
              = button_to(affordance_draft ? "Continue editing" : "Edit affordance",
                draft_schema_edit_affordance_path(@schema_wrapper, affordance),
                method: :post,
                form: { data: { turbo_frame: "main_content", turbo_action: "advance" } },
                class: "font-head inline-flex h-8 items-center justify-center rounded border-2 border-black bg-secondary px-3 text-sm font-medium text-secondary-foreground shadow-md transition-all hover:translate-y-1 hover:shadow-none")
              = button_to "New with this affordance",
                schema_documents_path(@schema_wrapper, edit_affordance_id: affordance.id),
                method: :post,
                form: { data: { turbo_frame: "main_content", turbo_action: "advance" } },
                class: "font-head inline-flex h-8 items-center justify-center rounded border-2 border-black bg-primary px-3 text-sm font-medium text-primary-foreground shadow-md transition-all hover:translate-y-1 hover:shadow-none"
    - else
      = render TypographyComponent.new(as: :muted, text: "No edit affordances exist for this schema yet.", html_options: { class: "mt-2" })

  .mt-6
    = render TypographyComponent.new(as: :h2, text: "Documents using this schema")

    - if @documents.any?
      %ul.mt-2.space-y-2
        - @documents.each do |document|
          %li
            = link_to document_path(document),
              data: { turbo_frame: "main_content", turbo_action: "advance" },
              class: "block rounded border-2 border-black bg-card px-3 py-2 text-card-foreground shadow-sm transition-all hover:translate-y-1 hover:shadow-none" do
              .font-head.font-medium= document.title.presence || document.key
              .text-xs.text-muted-foreground= document.key
    - else
      = render TypographyComponent.new(as: :muted, text: "No documents use this schema yet.", html_options: { class: "mt-2" })

  .mt-6
    %pre.rounded.border-2.border-black.bg-muted.p-4.text-sm.text-foreground.shadow-sm
      = JSON.pretty_generate(@schema_wrapper.body)

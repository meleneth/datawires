= turbo_frame_tag "main_content" do
  %section.space-y-6
    %header.space-y-2
      = render TypographyComponent.new(as: :h1, text: "Commit draft")
      = render TypographyComponent.new(as: :muted, text: "Enter a log message for this revision.")

    = render CardComponent.new(html_options: { class: "w-full" }) do
      = render CardContentComponent.new do
        %dl.grid.gap-3.text-sm
          %div
            %dt.text-muted-foreground Domain
            %dd.font-head.text-foreground= @domain.name
          %div
            %dt.text-muted-foreground Document
            %dd.font-head.text-foreground= @document.key
          %div
            %dt.text-muted-foreground Draft
            %dd.font-head.text-foreground= @draft.id

    = render "drafts/review", draft: @draft, diff_rows: @diff_rows

    = form_with url: draft_commit_path(@draft, path: @path, screen: @screen, edit_affordance_id: @edit_affordance_id),
                method: :post,
                scope: :commit,
                data: { turbo_frame: "main_content" },
                class: "space-y-4" do |f|
      - if @preflight&.warnings&.any?
        .space-y-3
          - @preflight.warnings.each do |warning|
            = render AlertComponent.new(variant: :destructive) do
              .space-y-3
                .font-head.font-medium
                  = warning.title
                %p.text-sm
                  = warning.message
                %label.flex.items-start.gap-2.text-sm
                  = check_box_tag "commit[confirmed_warnings][]",
                    warning.code,
                    false,
                    required: @preflight.unconfirmed_warnings.include?(warning)
                  %span
                    I understand and want to commit anyway.

      %div
        = render LabelComponent.new(text: "Log message", for_id: "commit_message", html_options: { class: "mb-2 block" })
        = f.text_area :message,
          rows: 4,
          class: "w-full rounded border-2 border-black bg-background px-3 py-2 text-sm text-foreground shadow-sm transition-all placeholder:text-muted-foreground focus-visible:outline-hidden focus-visible:shadow-md"

      .flex.items-center.gap-3
        = f.submit "Commit draft",
          name: nil,
          class: "font-head inline-flex h-10 items-center justify-center rounded border-2 border-black bg-primary px-4 py-2 font-medium text-primary-foreground shadow-md transition-all hover:translate-y-1 hover:shadow-none"
        = render ButtonComponent.new(href: draft_path(@draft, path: @path, screen: @screen, edit_affordance_id: @edit_affordance_id), variant: :outline, size: :sm, html_options: { data: { turbo_frame: "main_content" } }) do
          Back to editor

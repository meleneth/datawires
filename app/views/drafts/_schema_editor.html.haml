- schema_path = SchemaPath.new(path)
- raw_ptr = schema_path.json_ptr
- subschema = JsonPtr.get(draft.body, raw_ptr) || {}
- properties = subschema.fetch("properties", {})
- required = Array(subschema["required"])

= render SchemaNavRibbonComponent.new(domain: @domain, document: @document, draft: @draft, path: @path, turbo_frame: "editor")

.space-y-4
  .flex.items-center.justify-between
    %h3.text-lg.font-semibold.text-ink= "Schema: #{path}"

    = link_to "Commit…", new_draft_commit_path(draft), class: "inline-flex items-center rounded-lg border border-ls5-blue-5 bg-ls5-blue-4 px-3 py-2 font-medium text-ink-inverse hover:bg-ls5-blue-5"

  .space-y-3
    - properties.each do |name, prop_schema|
      .rounded-lg.border.border-ls5-violet-3.bg-white.p-3
        .flex.items-center.justify-between.gap-4
          .min-w-0
            .font-medium.text-ink= name
            .text-sm.text-ls5-violet-6= prop_schema["type"] || "(no type)"

            - if required.include?(name)
              .mt-1.text-xs.text-ls5-violet-5 required

          .flex.items-center.gap-2
            - if prop_schema.is_a?(Hash) && SchemaNav.new(draft.body).object_schema?(prop_schema)
              = link_to "Open", draft_path(draft, path: SchemaPath.new(path).child(name).to_s), data: { turbo_frame: "editor", turbo_action: "advance" }, class: "rounded-lg px-3 py-2 text-sm font-medium text-ls5-blue-4 hover:bg-ls5-violet-1"

  .rounded-lg.border.border-ls5-violet-3.bg-white.p-4
    %h4.mb-3.font-medium.text-ink Add property

    = form_with url: add_draft_schema_properties_path(draft), method: :patch, format: :turbo_stream, data: { turbo_frame: "editor" }, class: "space-y-4" do
      = hidden_field_tag :path, path

      .grid.gap-3.md:grid-cols-3
        .space-y-1
          = label_tag :name, "Name", class: "block text-sm font-medium text-ink"
          = text_field_tag :name, nil, class: "w-full rounded-md border border-ls5-violet-3 bg-white px-3 py-2 text-ink placeholder:text-ls5-violet-5 focus:outline-none focus:ring-2 focus:ring-ls5-blue-3 focus:border-ls5-blue-4"

        .space-y-1
          = label_tag :property_type, "Type", class: "block text-sm font-medium text-ink"
          = select_tag :property_type, options_for_select(%w[string integer number boolean object array]), class: "w-full rounded-md border border-ls5-violet-3 bg-white px-3 py-2 text-ink focus:outline-none focus:ring-2 focus:ring-ls5-blue-3 focus:border-ls5-blue-4"

        .flex.items-end.gap-3
          %label.flex.items-center.gap-2.text-ink
            = check_box_tag :required, "1", false, class: "rounded border-ls5-violet-3 text-ls5-blue-4 focus:ring-ls5-blue-3"
            %span Required

          = submit_tag "Add", class: "rounded-lg border border-ls5-blue-5 bg-ls5-blue-4 px-3 py-2 font-medium text-ink-inverse hover:bg-ls5-blue-5"

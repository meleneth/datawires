= render ThingCardComponent.new do |c|
  - c.with_label do
    = "#{@domain.name} / #{@document.key}"

  = link_to new_domain_document_draft_commit_path(@domain, @document, @draft),
    class: "inline-flex items-center rounded-lg bg-ls5-blue-4 px-3 py-2 font-medium text-ink-inverse hover:bg-ls5-blue-5" do
    Commit…

  is_schema:
  = @draft.is_json_schema?

  .grid{ style: "display:grid; grid-template-columns: 320px 1fr; gap: 16px;" }
    = turbo_frame_tag "ribbon" do
      = render "ribbon",
        domain: @domain,
        document: @document,
        draft: @draft,
        ptr: @ptr,
        mode: @mode

    = turbo_frame_tag "editor" do
      = render "editor",
        domain: @domain,
        document: @document,
        draft: @draft,
        ptr: @ptr,
        mode: @mode

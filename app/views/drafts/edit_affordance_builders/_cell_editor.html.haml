- builder_screen_params = local_assigns.fetch(:builder_screen_params, {})
- builder_path_params = ->(extra = {}) { builder_screen_params.merge(extra) }

= turbo_frame_tag "edit_affordance_builder_editor" do
  = render CardComponent.new(html_options: { class: "w-full" }) do
    = render CardContentComponent.new do
      .space-y-4
        .flex.flex-wrap.items-start.justify-between.gap-3
          .space-y-1
            = render TypographyComponent.new(as: :h3, text: "Field #{@cell_index + 1}")
            = render TypographyComponent.new(as: :muted, text: "Row #{@row_index + 1}")
          .flex.flex-wrap.gap-2
            = link_to "Back to row",
              row_draft_edit_affordance_builder_path(@draft, builder_path_params.call(row_index: @row_index)),
              data: { turbo_frame: "edit_affordance_builder_editor" },
              class: "font-head inline-flex h-9 items-center justify-center rounded border-2 border-black bg-background px-3 text-sm font-medium text-foreground shadow-sm transition-all hover:translate-y-1 hover:shadow-none"
            = button_to "Delete field",
              cell_draft_edit_affordance_builder_path(@draft, builder_path_params.call(row_index: @row_index, cell_index: @cell_index)),
              method: :delete,
              form: { data: { turbo_frame: "edit_affordance_builder_editor" } },
              class: "font-head inline-flex h-9 items-center justify-center rounded border-2 border-black bg-destructive px-3 text-sm font-medium text-destructive-foreground shadow-sm transition-all hover:translate-y-1 hover:shadow-none"

        - if @cell.key?("binding")
          - current_collection = @cell["collection"].is_a?(Hash) ? @cell["collection"] : {}
          - current_reference = @cell["reference"].is_a?(Hash) ? @cell["reference"] : {}
          - current_display = @cell["display"].is_a?(Hash) ? @cell["display"] : {}
          = form_with url: cell_draft_edit_affordance_builder_path(@draft, builder_path_params.call(row_index: @row_index, cell_index: @cell_index)),
            method: :patch,
            data: { turbo_frame: "edit_affordance_builder_editor", controller: "edit-affordance-builder" },
            class: "space-y-4" do
            .grid.gap-3.md:grid-cols-3
              .space-y-1
                = render LabelComponent.new(text: "Schema path", for_id: "cell_ptr")
                = select_tag :ptr,
                  options_for_select(@field_entries.map { |entry| ["#{entry.label} (#{entry.ptr})", entry.ptr, { "data-widget": entry.widget, "data-array": entry.array? ? "true" : "false" }] }, @cell.dig("binding", "ptr")),
                  id: "cell_ptr",
                  data: { edit_affordance_builder_target: "path", action: "edit-affordance-builder#sync" },
                  class: "flex h-10 w-full rounded border-2 border-black bg-background px-3 py-2 text-sm text-foreground shadow-sm transition-all focus-visible:outline-hidden focus-visible:shadow-md"
              .space-y-1
                = render LabelComponent.new(text: "Widget", for_id: "cell_widget")
                = select_tag :widget,
                  options_for_select(@widget_options, @cell["widget"] || "auto"),
                  id: "cell_widget",
                  class: "flex h-10 w-full rounded border-2 border-black bg-background px-3 py-2 text-sm text-foreground shadow-sm transition-all focus-visible:outline-hidden focus-visible:shadow-md"
              .space-y-1
                = render LabelComponent.new(text: "Span", for_id: "cell_span")
                = number_field_tag :span,
                  @cell["span"] || @selected_screen&.fetch("default_span", 3),
                  id: "cell_span",
                  min: 1,
                  max: 12,
                  class: "flex h-10 w-full rounded border-2 border-black bg-background px-3 py-2 text-sm text-foreground shadow-sm transition-all focus-visible:outline-hidden focus-visible:shadow-md"
              .space-y-1
                = render LabelComponent.new(text: "Help", for_id: "cell_help")
                = text_field_tag :help,
                  @cell["help"],
                  id: "cell_help",
                  class: "flex h-10 w-full rounded border-2 border-black bg-background px-3 py-2 text-sm text-foreground shadow-sm transition-all focus-visible:outline-hidden focus-visible:shadow-md"
              .space-y-1
                = render LabelComponent.new(text: "Placeholder", for_id: "cell_placeholder")
                = text_field_tag :placeholder,
                  @cell["placeholder"],
                  id: "cell_placeholder",
                  class: "flex h-10 w-full rounded border-2 border-black bg-background px-3 py-2 text-sm text-foreground shadow-sm transition-all focus-visible:outline-hidden focus-visible:shadow-md"
            %label.inline-flex.items-center.gap-2.text-sm{ for: "cell_label" }
              = check_box_tag :label, "1", @cell.fetch("label", true), id: "cell_label", class: "h-4 w-4 rounded border-2 border-black"
              %span Show label
            .flex.flex-wrap.gap-4
              %label.inline-flex.items-center.gap-2.text-sm{ for: "cell_display_compact" }
                = check_box_tag :display_compact, "1", current_display["compact"] == true, id: "cell_display_compact", class: "h-4 w-4 rounded border-2 border-black"
                %span Compact display
              %label.inline-flex.items-center.gap-2.text-sm{ for: "cell_display_readonly" }
                = check_box_tag :display_readonly, "1", current_display["readonly"] == true, id: "cell_display_readonly", class: "h-4 w-4 rounded border-2 border-black"
                %span Read-only display

            .rounded.border-2.border-black.bg-muted.p-3
              .mb-3.font-head.text-sm Reference options
              .grid.gap-3.md:grid-cols-3
                .space-y-1
                  = render LabelComponent.new(text: "Schema key", for_id: "cell_reference_schema_key")
                  = text_field_tag :reference_schema_key,
                    current_reference["schema_key"],
                    id: "cell_reference_schema_key",
                    placeholder: "person",
                    class: "flex h-10 w-full rounded border-2 border-black bg-background px-3 py-2 text-sm text-foreground shadow-sm transition-all placeholder:text-muted-foreground focus-visible:outline-hidden focus-visible:shadow-md"
                .space-y-1
                  = render LabelComponent.new(text: "Index type", for_id: "cell_reference_index_type")
                  = text_field_tag :reference_index_type,
                    current_reference["index_type"] || "identity",
                    id: "cell_reference_index_type",
                    class: "flex h-10 w-full rounded border-2 border-black bg-background px-3 py-2 text-sm text-foreground shadow-sm transition-all focus-visible:outline-hidden focus-visible:shadow-md"
                .space-y-1
                  = render LabelComponent.new(text: "Index key", for_id: "cell_reference_index_key")
                  = text_field_tag :reference_index_key,
                    current_reference["index_key"] || "document_key",
                    id: "cell_reference_index_key",
                    class: "flex h-10 w-full rounded border-2 border-black bg-background px-3 py-2 text-sm text-foreground shadow-sm transition-all focus-visible:outline-hidden focus-visible:shadow-md"
                .space-y-1
                  = render LabelComponent.new(text: "Schema key from", for_id: "cell_reference_schema_key_from")
                  = text_field_tag :reference_schema_key_from,
                    current_reference["schema_key_from"],
                    id: "cell_reference_schema_key_from",
                    placeholder: "/kind",
                    class: "flex h-10 w-full rounded border-2 border-black bg-background px-3 py-2 text-sm text-foreground shadow-sm transition-all placeholder:text-muted-foreground focus-visible:outline-hidden focus-visible:shadow-md"
                .space-y-1
                  = render LabelComponent.new(text: "Reference placeholder", for_id: "cell_reference_placeholder")
                  = text_field_tag :reference_placeholder,
                    current_reference["placeholder"],
                    id: "cell_reference_placeholder",
                    placeholder: "Select reference",
                    class: "flex h-10 w-full rounded border-2 border-black bg-background px-3 py-2 text-sm text-foreground shadow-sm transition-all placeholder:text-muted-foreground focus-visible:outline-hidden focus-visible:shadow-md"

            .rounded.border-2.border-black.bg-muted.p-3{ data: { edit_affordance_builder_target: "collection" } }
              .mb-3.font-head.text-sm Collection options
              .grid.gap-3.md:grid-cols-3
                .space-y-1
                  = render LabelComponent.new(text: "Presentation", for_id: "collection_presentation")
                  = select_tag :collection_presentation,
                    options_for_select(%w[list table cards], current_collection["presentation"]),
                    class: "flex h-10 w-full rounded border-2 border-black bg-background px-3 py-2 text-sm text-foreground shadow-sm transition-all focus-visible:outline-hidden focus-visible:shadow-md"
                .space-y-1
                  = render LabelComponent.new(text: "Creation", for_id: "collection_creation")
                  = select_tag :collection_creation,
                    options_for_select(@collection_creation_options, current_collection["creation"]),
                    class: "flex h-10 w-full rounded border-2 border-black bg-background px-3 py-2 text-sm text-foreground shadow-sm transition-all focus-visible:outline-hidden focus-visible:shadow-md"
                .space-y-1
                  = render LabelComponent.new(text: "Item screen", for_id: "collection_item_screen")
                  = select_tag :collection_item_screen,
                    options_for_select([["None", ""]] + @screen_ids.map { |screen_id| [screen_id, screen_id] }, current_collection["item_screen"]),
                    class: "flex h-10 w-full rounded border-2 border-black bg-background px-3 py-2 text-sm text-foreground shadow-sm transition-all focus-visible:outline-hidden focus-visible:shadow-md"
                .space-y-1
                  = render LabelComponent.new(text: "Delete", for_id: "collection_delete")
                  = select_tag :collection_delete,
                    options_for_select(%w[disabled enabled], current_collection["delete"]),
                    class: "flex h-10 w-full rounded border-2 border-black bg-background px-3 py-2 text-sm text-foreground shadow-sm transition-all focus-visible:outline-hidden focus-visible:shadow-md"
                .space-y-1
                  = render LabelComponent.new(text: "Reorder", for_id: "collection_reorder")
                  = select_tag :collection_reorder,
                    options_for_select(%w[disabled enabled], current_collection["reorder"]),
                    class: "flex h-10 w-full rounded border-2 border-black bg-background px-3 py-2 text-sm text-foreground shadow-sm transition-all focus-visible:outline-hidden focus-visible:shadow-md"
              .mt-3.grid.gap-3.md:grid-cols-2
                .grid.gap-2.md:grid-cols-2
                  .space-y-1
                    = render LabelComponent.new(text: "Title binding", for_id: "item_title_kind")
                    = select_tag :item_title_kind,
                      options_for_select(@collection_binding_options, current_collection.dig("item_title", "kind") || "property"),
                      class: "flex h-10 w-full rounded border-2 border-black bg-background px-3 py-2 text-sm text-foreground shadow-sm transition-all focus-visible:outline-hidden focus-visible:shadow-md"
                  .space-y-1
                    = render LabelComponent.new(text: "Title property", for_id: "item_title_name")
                    = text_field_tag :item_title_name,
                      current_collection.dig("item_title", "name") || "name",
                      class: "flex h-10 w-full rounded border-2 border-black bg-background px-3 py-2 text-sm text-foreground shadow-sm transition-all focus-visible:outline-hidden focus-visible:shadow-md"
                  .space-y-1
                    = render LabelComponent.new(text: "Title reference schema", for_id: "item_title_schema_key")
                    = text_field_tag :item_title_schema_key,
                      current_collection.dig("item_title", "schema_key"),
                      placeholder: "person",
                      class: "flex h-10 w-full rounded border-2 border-black bg-background px-3 py-2 text-sm text-foreground shadow-sm transition-all placeholder:text-muted-foreground focus-visible:outline-hidden focus-visible:shadow-md"
                  .space-y-1
                    = render LabelComponent.new(text: "Title reference schema property", for_id: "item_title_schema_key_property")
                    = text_field_tag :item_title_schema_key_property,
                      current_collection.dig("item_title", "schema_key_property") || "kind",
                      class: "flex h-10 w-full rounded border-2 border-black bg-background px-3 py-2 text-sm text-foreground shadow-sm transition-all focus-visible:outline-hidden focus-visible:shadow-md"
                  .space-y-1
                    = render LabelComponent.new(text: "Title reference key property", for_id: "item_title_key_property")
                    = text_field_tag :item_title_key_property,
                      current_collection.dig("item_title", "key_property") || "key",
                      class: "flex h-10 w-full rounded border-2 border-black bg-background px-3 py-2 text-sm text-foreground shadow-sm transition-all focus-visible:outline-hidden focus-visible:shadow-md"
                  .space-y-1
                    = render LabelComponent.new(text: "Title reference index key", for_id: "item_title_index_key")
                    = text_field_tag :item_title_index_key,
                      current_collection.dig("item_title", "index_key") || "document_key",
                      class: "flex h-10 w-full rounded border-2 border-black bg-background px-3 py-2 text-sm text-foreground shadow-sm transition-all focus-visible:outline-hidden focus-visible:shadow-md"
                .grid.gap-2.md:grid-cols-2
                  .space-y-1
                    = render LabelComponent.new(text: "Subtitle binding", for_id: "item_subtitle_kind")
                    = select_tag :item_subtitle_kind,
                      options_for_select(@collection_binding_options, current_collection.dig("item_subtitle", "kind") || "value_label"),
                      class: "flex h-10 w-full rounded border-2 border-black bg-background px-3 py-2 text-sm text-foreground shadow-sm transition-all focus-visible:outline-hidden focus-visible:shadow-md"
                  .space-y-1
                    = render LabelComponent.new(text: "Subtitle property", for_id: "item_subtitle_name")
                    = text_field_tag :item_subtitle_name,
                      current_collection.dig("item_subtitle", "name"),
                      class: "flex h-10 w-full rounded border-2 border-black bg-background px-3 py-2 text-sm text-foreground shadow-sm transition-all focus-visible:outline-hidden focus-visible:shadow-md"
                  .space-y-1
                    = render LabelComponent.new(text: "Subtitle reference schema", for_id: "item_subtitle_schema_key")
                    = text_field_tag :item_subtitle_schema_key,
                      current_collection.dig("item_subtitle", "schema_key"),
                      placeholder: "person",
                      class: "flex h-10 w-full rounded border-2 border-black bg-background px-3 py-2 text-sm text-foreground shadow-sm transition-all placeholder:text-muted-foreground focus-visible:outline-hidden focus-visible:shadow-md"
                  .space-y-1
                    = render LabelComponent.new(text: "Subtitle reference schema property", for_id: "item_subtitle_schema_key_property")
                    = text_field_tag :item_subtitle_schema_key_property,
                      current_collection.dig("item_subtitle", "schema_key_property") || "kind",
                      class: "flex h-10 w-full rounded border-2 border-black bg-background px-3 py-2 text-sm text-foreground shadow-sm transition-all focus-visible:outline-hidden focus-visible:shadow-md"
                  .space-y-1
                    = render LabelComponent.new(text: "Subtitle reference key property", for_id: "item_subtitle_key_property")
                    = text_field_tag :item_subtitle_key_property,
                      current_collection.dig("item_subtitle", "key_property") || "key",
                      class: "flex h-10 w-full rounded border-2 border-black bg-background px-3 py-2 text-sm text-foreground shadow-sm transition-all focus-visible:outline-hidden focus-visible:shadow-md"
                  .space-y-1
                    = render LabelComponent.new(text: "Subtitle reference index key", for_id: "item_subtitle_index_key")
                    = text_field_tag :item_subtitle_index_key,
                      current_collection.dig("item_subtitle", "index_key") || "document_key",
                      class: "flex h-10 w-full rounded border-2 border-black bg-background px-3 py-2 text-sm text-foreground shadow-sm transition-all focus-visible:outline-hidden focus-visible:shadow-md"
              .rounded.border-2.border-black.bg-muted.p-3.text-sm.text-muted-foreground{ data: { edit_affordance_builder_target: "collectionNote" } }
                Collection policy: array fields only.
            .flex.justify-end
              = submit_tag "Update field",
                class: "font-head inline-flex h-10 items-center justify-center rounded border-2 border-black bg-primary px-4 py-2 font-medium text-primary-foreground shadow-md transition-all hover:translate-y-1 hover:shadow-none"
        - elsif @cell["kind"] == "navigation"
          = form_with url: cell_draft_edit_affordance_builder_path(@draft, builder_path_params.call(row_index: @row_index, cell_index: @cell_index)),
            method: :patch,
            data: { turbo_frame: "edit_affordance_builder_editor" },
            class: "space-y-4" do
            .grid.gap-3.md:grid-cols-3
              .space-y-1
                = render LabelComponent.new(text: "Target screen", for_id: "target_screen")
                = select_tag :target_screen,
                  options_for_select(@screen_ids.map { |screen_id| [screen_id, screen_id] }, @cell["target_screen"]),
                  class: "flex h-10 w-full rounded border-2 border-black bg-background px-3 py-2 text-sm text-foreground shadow-sm transition-all focus-visible:outline-hidden focus-visible:shadow-md"
              .space-y-1
                = render LabelComponent.new(text: "Label", for_id: "navigation_label")
                = text_field_tag :navigation_label,
                  @cell["label"],
                  class: "flex h-10 w-full rounded border-2 border-black bg-background px-3 py-2 text-sm text-foreground shadow-sm transition-all focus-visible:outline-hidden focus-visible:shadow-md"
              .space-y-1
                = render LabelComponent.new(text: "Span", for_id: "navigation_span")
                = number_field_tag :navigation_span,
                  @cell["span"] || @selected_screen&.fetch("default_span", 3),
                  min: 1,
                  max: 12,
                  class: "flex h-10 w-full rounded border-2 border-black bg-background px-3 py-2 text-sm text-foreground shadow-sm transition-all focus-visible:outline-hidden focus-visible:shadow-md"
            = submit_tag "Update navigation",
              class: "font-head inline-flex h-10 items-center justify-center rounded border-2 border-black bg-primary px-4 py-2 font-medium text-primary-foreground shadow-md transition-all hover:translate-y-1 hover:shadow-none"
        - elsif @cell["kind"] == "commit"
          = form_with url: cell_draft_edit_affordance_builder_path(@draft, builder_path_params.call(row_index: @row_index, cell_index: @cell_index)),
            method: :patch,
            data: { turbo_frame: "edit_affordance_builder_editor" },
            class: "space-y-4" do
            .grid.gap-3.md:grid-cols-3
              .space-y-1
                = render LabelComponent.new(text: "Span", for_id: "commit_span")
                = number_field_tag :commit_span,
                  @cell["span"] || @selected_screen&.fetch("default_span", 3),
                  min: 1,
                  max: 12,
                  class: "flex h-10 w-full rounded border-2 border-black bg-background px-3 py-2 text-sm text-foreground shadow-sm transition-all focus-visible:outline-hidden focus-visible:shadow-md"
              .space-y-1
                = render LabelComponent.new(text: "Commit mode", for_id: "commit_mode")
                = select_tag :commit_mode,
                  options_for_select([["Review screen", "review_screen"], ["Immediate", "immediate"]], @cell["commit_mode"] || "review_screen"),
                  class: "flex h-10 w-full rounded border-2 border-black bg-background px-3 py-2 text-sm text-foreground shadow-sm transition-all focus-visible:outline-hidden focus-visible:shadow-md"
              .space-y-1
                = render LabelComponent.new(text: "Message mode", for_id: "message_mode")
                = select_tag :message_mode,
                  options_for_select([["Hidden", "hidden"], ["Inline optional", "inline_optional"], ["Inline required", "inline_required"]], @cell["message_mode"] || "inline_optional"),
                  class: "flex h-10 w-full rounded border-2 border-black bg-background px-3 py-2 text-sm text-foreground shadow-sm transition-all focus-visible:outline-hidden focus-visible:shadow-md"
            = submit_tag "Update commit",
              class: "font-head inline-flex h-10 items-center justify-center rounded border-2 border-black bg-primary px-4 py-2 font-medium text-primary-foreground shadow-md transition-all hover:translate-y-1 hover:shadow-none"
        - else
          = render AlertComponent.new(variant: :destructive) do
            This cell can be repaired from the Raw tab.

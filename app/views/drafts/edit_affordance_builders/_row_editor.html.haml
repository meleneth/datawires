- builder_screen_params = local_assigns.fetch(:builder_screen_params, {})
- builder_path_params = ->(extra = {}) { builder_screen_params.merge(extra) }

= turbo_frame_tag "edit_affordance_builder_editor" do
  = render CardComponent.new(html_options: { class: "w-full" }) do
    = render CardContentComponent.new do
      .space-y-4
        .flex.flex-wrap.items-center.justify-between.gap-3
          .space-y-1
            = render TypographyComponent.new(as: :h3, text: "Row #{@row_index + 1}")
            = render TypographyComponent.new(as: :muted, text: pluralize(@row.length, "field"))
          .flex.flex-wrap.gap-2
            = link_to "Back to builder",
              draft_edit_affordance_builder_path(@draft, builder_path_params.call(tab: "builder")),
              data: { turbo_frame: "main_content" },
              class: "font-head inline-flex h-9 items-center justify-center rounded border-2 border-black bg-background px-3 text-sm font-medium text-foreground shadow-sm transition-all hover:translate-y-1 hover:shadow-none"
            = button_to "Delete row",
              row_draft_edit_affordance_builder_path(@draft, builder_path_params.call(row_index: @row_index)),
              method: :delete,
              form: { data: { turbo_frame: "edit_affordance_builder_editor" } },
              class: "font-head inline-flex h-9 items-center justify-center rounded border-2 border-black bg-destructive px-3 text-sm font-medium text-destructive-foreground shadow-sm transition-all hover:translate-y-1 hover:shadow-none"

        - if @row.empty?
          = render AlertComponent.new do
            Empty row.
        - else
          %ol.space-y-2
            - @row.each_with_index do |cell, cell_index|
              %li.rounded.border-2.border-black.bg-card.p-3.text-sm.shadow-sm
                .flex.flex-wrap.items-start.justify-between.gap-3
                  .space-y-1
                    .font-head Field #{cell_index + 1}
                    .font-mono.text-xs.text-muted-foreground= cell.dig("binding", "ptr") || cell["kind"]
                    .text-xs.text-muted-foreground
                      Span #{cell["span"] || @selected_screen&.fetch("default_span", 3)}
                  .flex.flex-wrap.gap-2
                    - if cell_index.positive?
                      = button_to "Left",
                        move_cell_draft_edit_affordance_builder_path(@draft, builder_path_params.call(row_index: @row_index, cell_index: cell_index)),
                        method: :patch,
                        params: { direction: "left" },
                        form: { data: { turbo_frame: "edit_affordance_builder_editor" } },
                        class: "font-head inline-flex h-8 items-center justify-center rounded border-2 border-black bg-background px-3 text-xs font-medium text-foreground shadow-sm transition-all hover:translate-y-1 hover:shadow-none"
                    - if cell_index < @row.length - 1
                      = button_to "Right",
                        move_cell_draft_edit_affordance_builder_path(@draft, builder_path_params.call(row_index: @row_index, cell_index: cell_index)),
                        method: :patch,
                        params: { direction: "right" },
                        form: { data: { turbo_frame: "edit_affordance_builder_editor" } },
                        class: "font-head inline-flex h-8 items-center justify-center rounded border-2 border-black bg-background px-3 text-xs font-medium text-foreground shadow-sm transition-all hover:translate-y-1 hover:shadow-none"
                    = link_to "Open",
                      cell_draft_edit_affordance_builder_path(@draft, builder_path_params.call(row_index: @row_index, cell_index: cell_index)),
                      data: { turbo_frame: "edit_affordance_builder_editor" },
                      class: "font-head inline-flex h-8 items-center justify-center rounded border-2 border-black bg-background px-3 text-xs font-medium text-foreground shadow-sm transition-all hover:translate-y-1 hover:shadow-none"
                    = button_to "Delete",
                      cell_draft_edit_affordance_builder_path(@draft, builder_path_params.call(row_index: @row_index, cell_index: cell_index)),
                      method: :delete,
                      form: { data: { turbo_frame: "edit_affordance_builder_editor" } },
                      class: "font-head inline-flex h-8 items-center justify-center rounded border-2 border-black bg-destructive px-3 text-xs font-medium text-destructive-foreground shadow-sm transition-all hover:translate-y-1 hover:shadow-none"

= turbo_frame_tag "main_content" do
  - builder_screen_params = @screen_id == "main" ? {} : { screen_id: @screen_id }
  - builder_path_params = ->(extra = {}) { builder_screen_params.merge(extra) }
  %section{ class: "mx-auto w-full space-y-6", style: "max-width: 1920px;" }
    %header.space-y-2
      = render TypographyComponent.new(as: :h1, text: "Edit affordance builder")
      = render TypographyComponent.new(as: :muted, text: "#{@edit_affordance.title} for #{@schema_wrapper.key}")

    .flex.flex-wrap.items-center.gap-2
      - %w[builder preview diagnostics raw].each do |tab|
        = link_to tab.titleize,
          draft_edit_affordance_builder_path(@draft, builder_path_params.call(tab: tab)),
          data: { turbo_frame: "main_content" },
          class: "font-head inline-flex h-9 items-center justify-center rounded border-2 border-black px-3 text-sm font-medium shadow-sm transition-all hover:translate-y-1 hover:shadow-none #{@tab == tab ? 'bg-primary text-primary-foreground' : 'bg-background text-foreground'}"
      = render ButtonComponent.new(href: new_draft_commit_path(@draft), size: :sm, html_options: { data: { turbo_frame: "main_content" } }) do
        Commit affordance
      = button_to "Delete affordance",
        affordance_draft_edit_affordance_builder_path(@draft),
        method: :delete,
        form: { data: { turbo_frame: "main_content", turbo_action: "advance", turbo_confirm: "Delete this edit affordance? This cannot be undone." } },
        class: "font-head inline-flex h-9 items-center justify-center rounded border-2 border-black bg-destructive px-3 text-sm font-medium text-destructive-foreground shadow-sm transition-all hover:translate-y-1 hover:shadow-none"

    - if flash[:alert].present?
      = render AlertComponent.new(variant: :destructive) do
        = flash[:alert]
    - if flash[:notice].present?
      = render AlertComponent.new do
        = flash[:notice]

    - if @tab == "builder"
      - row_options = @rows.each_with_index.map { |_row, index| ["Row #{index + 1}", index] }
      = render CardComponent.new(html_options: { class: "w-full" }) do
        = render CardContentComponent.new do
          .space-y-4
            = render TypographyComponent.new(as: :h3, text: "Screens")
            .flex.flex-wrap.gap-2
              - @screen_ids.each do |screen_id|
                = link_to screen_id,
                  draft_edit_affordance_builder_path(@draft, screen_id == "main" ? { tab: "builder" } : { tab: "builder", screen_id: screen_id }),
                  data: { turbo_frame: "main_content" },
                  class: "font-head inline-flex h-8 items-center justify-center rounded border-2 border-black px-3 text-xs font-medium shadow-sm transition-all hover:translate-y-1 hover:shadow-none #{screen_id == @screen_id ? 'bg-primary text-primary-foreground' : 'bg-background text-foreground'}"
            .grid.gap-6.lg:grid-cols-2
              .space-y-3
                = render TypographyComponent.new(as: :h3, text: "Add screen")
                = form_with url: add_screen_draft_edit_affordance_builder_path(@draft, builder_screen_params),
                  method: :patch,
                  data: { turbo_frame: "main_content" },
                  class: "space-y-3" do
                  .grid.gap-3.md:grid-cols-2
                    .space-y-1
                      = render LabelComponent.new(text: "Screen id", for_id: "new_screen_id")
                      = text_field_tag :new_screen_id,
                        nil,
                        placeholder: "details",
                        class: "flex h-10 w-full rounded border-2 border-black bg-background px-3 py-2 text-sm text-foreground shadow-sm transition-all placeholder:text-muted-foreground focus-visible:outline-hidden focus-visible:shadow-md"
                    .space-y-1
                      = render LabelComponent.new(text: "Title", for_id: "new_screen_title")
                      = text_field_tag :new_screen_title,
                        nil,
                        placeholder: "Details",
                        class: "flex h-10 w-full rounded border-2 border-black bg-background px-3 py-2 text-sm text-foreground shadow-sm transition-all placeholder:text-muted-foreground focus-visible:outline-hidden focus-visible:shadow-md"
                    .space-y-1
                      = render LabelComponent.new(text: "Root pointer", for_id: "new_screen_root_ptr")
                      = text_field_tag :new_screen_root_ptr,
                        nil,
                        placeholder: "/profile",
                        class: "flex h-10 w-full rounded border-2 border-black bg-background px-3 py-2 text-sm text-foreground shadow-sm transition-all placeholder:text-muted-foreground focus-visible:outline-hidden focus-visible:shadow-md"
                    .space-y-1
                      = render LabelComponent.new(text: "Subform", for_id: "new_screen_subform")
                      = select_tag :new_screen_subform,
                        options_for_select([["None", ""]] + @subform_ids.map { |subform_id| [subform_id, subform_id] }),
                        class: "flex h-10 w-full rounded border-2 border-black bg-background px-3 py-2 text-sm text-foreground shadow-sm transition-all focus-visible:outline-hidden focus-visible:shadow-md"
                    .space-y-1
                      = render LabelComponent.new(text: "Width", for_id: "new_screen_width")
                      = select_tag :new_screen_width,
                        options_for_select([["Narrow", "narrow"], ["Medium", "medium"], ["Large", "large"], ["Full", "full"]], "large"),
                        class: "flex h-10 w-full rounded border-2 border-black bg-background px-3 py-2 text-sm text-foreground shadow-sm transition-all focus-visible:outline-hidden focus-visible:shadow-md"
                    .space-y-1
                      = render LabelComponent.new(text: "Mode", for_id: "new_screen_mode")
                      = select_tag :new_screen_mode,
                        options_for_select(@screen_mode_options.map { |mode| [mode.humanize, mode] }, "page"),
                        class: "flex h-10 w-full rounded border-2 border-black bg-background px-3 py-2 text-sm text-foreground shadow-sm transition-all focus-visible:outline-hidden focus-visible:shadow-md"
                    .space-y-1
                      = render LabelComponent.new(text: "Default span", for_id: "new_screen_default_span")
                      = number_field_tag :new_screen_default_span,
                        3,
                        min: 1,
                        max: 12,
                        class: "flex h-10 w-full rounded border-2 border-black bg-background px-3 py-2 text-sm text-foreground shadow-sm transition-all focus-visible:outline-hidden focus-visible:shadow-md"
                    .space-y-1
                      = render LabelComponent.new(text: "Commit mode", for_id: "new_screen_commit_mode")
                      = select_tag :new_screen_commit_mode,
                        options_for_select([["Review screen", "review_screen"], ["Immediate", "immediate"]], "review_screen"),
                        class: "flex h-10 w-full rounded border-2 border-black bg-background px-3 py-2 text-sm text-foreground shadow-sm transition-all focus-visible:outline-hidden focus-visible:shadow-md"
                  = submit_tag "Add screen",
                    class: "font-head inline-flex h-10 items-center justify-center rounded border-2 border-black bg-primary px-4 py-2 font-medium text-primary-foreground shadow-md transition-all hover:translate-y-1 hover:shadow-none"
              .space-y-3
                = render TypographyComponent.new(as: :h3, text: "Add subform")
                = form_with url: add_subform_draft_edit_affordance_builder_path(@draft, builder_screen_params),
                  method: :patch,
                  data: { turbo_frame: "main_content" },
                  class: "space-y-3" do
                  .grid.gap-3.md:grid-cols-2
                    .space-y-1
                      = render LabelComponent.new(text: "Subform id", for_id: "new_subform_id")
                      = text_field_tag :new_subform_id,
                        nil,
                        placeholder: "profile_fields",
                        class: "flex h-10 w-full rounded border-2 border-black bg-background px-3 py-2 text-sm text-foreground shadow-sm transition-all placeholder:text-muted-foreground focus-visible:outline-hidden focus-visible:shadow-md"
                    .space-y-1
                      = render LabelComponent.new(text: "Root pointer", for_id: "new_subform_root_ptr")
                      = text_field_tag :new_subform_root_ptr,
                        nil,
                        placeholder: "/profile",
                        class: "flex h-10 w-full rounded border-2 border-black bg-background px-3 py-2 text-sm text-foreground shadow-sm transition-all placeholder:text-muted-foreground focus-visible:outline-hidden focus-visible:shadow-md"
                  = submit_tag "Add subform",
                    class: "font-head inline-flex h-10 items-center justify-center rounded border-2 border-black bg-primary px-4 py-2 font-medium text-primary-foreground shadow-md transition-all hover:translate-y-1 hover:shadow-none"

      = render CardComponent.new(html_options: { class: "w-full" }) do
        = render CardContentComponent.new do
          .space-y-4
            = render TypographyComponent.new(as: :h3, text: "Screen layout")
            - if @active_subform
              = render TypographyComponent.new(as: :muted, text: "Rows edit subform #{@active_subform.fetch('id')}.")
            = form_with url: update_screen_draft_edit_affordance_builder_path(@draft, builder_screen_params),
              method: :patch,
              data: { turbo_frame: "main_content" },
              class: "grid gap-3 md:grid-cols-3" do
              .space-y-1
                = render LabelComponent.new(text: "Start screen", for_id: "start_screen")
                = select_tag :start_screen,
                  options_for_select(@screen_ids.map { |screen_id| [screen_id, screen_id] }, @draft.body["start_screen"].presence || "main"),
                  class: "flex h-10 w-full rounded border-2 border-black bg-background px-3 py-2 text-sm text-foreground shadow-sm transition-all focus-visible:outline-hidden focus-visible:shadow-md"
              .space-y-1
                = render LabelComponent.new(text: "Default commit mode", for_id: "default_commit_mode")
                = select_tag :default_commit_mode,
                  options_for_select([["Review screen", "review_screen"], ["Immediate", "immediate"]], @draft.body["commit_mode"].presence || "review_screen"),
                  class: "flex h-10 w-full rounded border-2 border-black bg-background px-3 py-2 text-sm text-foreground shadow-sm transition-all focus-visible:outline-hidden focus-visible:shadow-md"
              .space-y-1
                = render LabelComponent.new(text: "Title", for_id: "title")
                = text_field_tag :title,
                  @selected_screen&.fetch("title", nil),
                  class: "flex h-10 w-full rounded border-2 border-black bg-background px-3 py-2 text-sm text-foreground shadow-sm transition-all focus-visible:outline-hidden focus-visible:shadow-md"
              .space-y-1
                = render LabelComponent.new(text: "Root pointer", for_id: "root_ptr")
                = text_field_tag :root_ptr,
                  @selected_screen&.dig("root_binding", "ptr"),
                  placeholder: "/profile",
                  class: "flex h-10 w-full rounded border-2 border-black bg-background px-3 py-2 text-sm text-foreground shadow-sm transition-all placeholder:text-muted-foreground focus-visible:outline-hidden focus-visible:shadow-md"
              .space-y-1
                = render LabelComponent.new(text: "Subform", for_id: "subform")
                = select_tag :subform,
                  options_for_select([["None", ""]] + @subform_ids.map { |subform_id| [subform_id, subform_id] }, @selected_screen&.fetch("subform", nil)),
                  class: "flex h-10 w-full rounded border-2 border-black bg-background px-3 py-2 text-sm text-foreground shadow-sm transition-all focus-visible:outline-hidden focus-visible:shadow-md"
              - if @active_subform
                .space-y-1
                  = render LabelComponent.new(text: "Subform root pointer", for_id: "subform_root_ptr")
                  = text_field_tag :subform_root_ptr,
                    @active_subform.dig("root_binding", "ptr"),
                    placeholder: "/profile",
                    class: "flex h-10 w-full rounded border-2 border-black bg-background px-3 py-2 text-sm text-foreground shadow-sm transition-all placeholder:text-muted-foreground focus-visible:outline-hidden focus-visible:shadow-md"
              .space-y-1
                = render LabelComponent.new(text: "Width", for_id: "width")
                = select_tag :width,
                  options_for_select([["Narrow", "narrow"], ["Medium", "medium"], ["Large", "large"], ["Full", "full"]], @selected_screen&.fetch("width", "large")),
                  class: "flex h-10 w-full rounded border-2 border-black bg-background px-3 py-2 text-sm text-foreground shadow-sm transition-all focus-visible:outline-hidden focus-visible:shadow-md"
              .space-y-1
                = render LabelComponent.new(text: "Mode", for_id: "screen_mode")
                = select_tag :screen_mode,
                  options_for_select(@screen_mode_options.map { |mode| [mode.humanize, mode] }, @selected_screen&.fetch("mode", "page")),
                  class: "flex h-10 w-full rounded border-2 border-black bg-background px-3 py-2 text-sm text-foreground shadow-sm transition-all focus-visible:outline-hidden focus-visible:shadow-md"
              .space-y-1
                = render LabelComponent.new(text: "Default span", for_id: "default_span")
                = number_field_tag :default_span,
                  @selected_screen&.fetch("default_span", 3),
                  min: 1,
                  max: 12,
                  class: "flex h-10 w-full rounded border-2 border-black bg-background px-3 py-2 text-sm text-foreground shadow-sm transition-all focus-visible:outline-hidden focus-visible:shadow-md"
              .space-y-1
                = render LabelComponent.new(text: "Commit mode", for_id: "screen_commit_mode")
                = select_tag :screen_commit_mode,
                  options_for_select([["Review screen", "review_screen"], ["Immediate", "immediate"]], @selected_screen&.fetch("commit_mode", "review_screen")),
                  class: "flex h-10 w-full rounded border-2 border-black bg-background px-3 py-2 text-sm text-foreground shadow-sm transition-all focus-visible:outline-hidden focus-visible:shadow-md"
              .flex.items-end
                = submit_tag "Update layout",
                  class: "font-head inline-flex h-10 items-center justify-center rounded border-2 border-black bg-primary px-4 py-2 font-medium text-primary-foreground shadow-md transition-all hover:translate-y-1 hover:shadow-none"

            = button_to "Add row",
              add_row_draft_edit_affordance_builder_path(@draft, builder_screen_params),
              method: :patch,
              form: { data: { turbo_frame: "main_content" } },
              class: "font-head inline-flex h-9 items-center justify-center rounded border-2 border-black bg-background px-3 text-sm font-medium text-foreground shadow-md transition-all hover:translate-y-1 hover:shadow-none"

      = render CardComponent.new(html_options: { class: "w-full" }) do
        = render CardContentComponent.new do
          .space-y-4
            = render TypographyComponent.new(as: :h3, text: "Add field")
            - if @rows.empty?
              = render AlertComponent.new do
                Add a row before adding fields.
            = form_with url: add_field_draft_edit_affordance_builder_path(@draft, builder_screen_params),
              method: :patch,
              data: { turbo_frame: "main_content", controller: "edit-affordance-builder" },
              class: "space-y-4" do
              .grid.gap-3.md:grid-cols-3
                .space-y-1
                  = render LabelComponent.new(text: "Schema path", for_id: "ptr")
                  = select_tag :ptr,
                    options_for_select(@field_entries.map { |entry| ["#{entry.label} (#{entry.ptr})", entry.ptr, { "data-widget": entry.widget, "data-array": entry.array? ? "true" : "false" }] }),
                    data: { edit_affordance_builder_target: "path", action: "edit-affordance-builder#sync" },
                    class: "flex h-10 w-full rounded border-2 border-black bg-background px-3 py-2 text-sm text-foreground shadow-sm transition-all focus-visible:outline-hidden focus-visible:shadow-md"
                .space-y-1
                  = render LabelComponent.new(text: "Widget", for_id: "widget")
                  = select_tag :widget,
                    options_for_select(@widget_options),
                    class: "flex h-10 w-full rounded border-2 border-black bg-background px-3 py-2 text-sm text-foreground shadow-sm transition-all focus-visible:outline-hidden focus-visible:shadow-md"
                .space-y-1
                  = render LabelComponent.new(text: "Row", for_id: "row_index")
                  = select_tag :row_index,
                    options_for_select(row_options, @rows.empty? ? nil : @rows.length - 1),
                    class: "flex h-10 w-full rounded border-2 border-black bg-background px-3 py-2 text-sm text-foreground shadow-sm transition-all focus-visible:outline-hidden focus-visible:shadow-md"
                .space-y-1
                  = render LabelComponent.new(text: "Span", for_id: "span")
                  = number_field_tag :span,
                    3,
                    min: 1,
                    max: 12,
                    class: "flex h-10 w-full rounded border-2 border-black bg-background px-3 py-2 text-sm text-foreground shadow-sm transition-all focus-visible:outline-hidden focus-visible:shadow-md"
                .space-y-1
                  = render LabelComponent.new(text: "Help", for_id: "help")
                  = text_field_tag :help,
                    nil,
                    class: "flex h-10 w-full rounded border-2 border-black bg-background px-3 py-2 text-sm text-foreground shadow-sm transition-all focus-visible:outline-hidden focus-visible:shadow-md"
                .space-y-1
                  = render LabelComponent.new(text: "Placeholder", for_id: "placeholder")
                  = text_field_tag :placeholder,
                    nil,
                    class: "flex h-10 w-full rounded border-2 border-black bg-background px-3 py-2 text-sm text-foreground shadow-sm transition-all focus-visible:outline-hidden focus-visible:shadow-md"
              .rounded.border-2.border-black.bg-muted.p-3
                .mb-3.font-head.text-sm Reference options
                .grid.gap-3.md:grid-cols-3
                  .space-y-1
                    = render LabelComponent.new(text: "Schema key", for_id: "reference_schema_key")
                    = text_field_tag :reference_schema_key,
                      nil,
                      placeholder: "person",
                      class: "flex h-10 w-full rounded border-2 border-black bg-background px-3 py-2 text-sm text-foreground shadow-sm transition-all placeholder:text-muted-foreground focus-visible:outline-hidden focus-visible:shadow-md"
                  .space-y-1
                    = render LabelComponent.new(text: "Index type", for_id: "reference_index_type")
                    = text_field_tag :reference_index_type,
                      "identity",
                      class: "flex h-10 w-full rounded border-2 border-black bg-background px-3 py-2 text-sm text-foreground shadow-sm transition-all focus-visible:outline-hidden focus-visible:shadow-md"
                  .space-y-1
                    = render LabelComponent.new(text: "Index key", for_id: "reference_index_key")
                    = text_field_tag :reference_index_key,
                      "document_key",
                      class: "flex h-10 w-full rounded border-2 border-black bg-background px-3 py-2 text-sm text-foreground shadow-sm transition-all focus-visible:outline-hidden focus-visible:shadow-md"
                  .space-y-1
                    = render LabelComponent.new(text: "Schema key from", for_id: "reference_schema_key_from")
                    = text_field_tag :reference_schema_key_from,
                      nil,
                      placeholder: "/kind",
                      class: "flex h-10 w-full rounded border-2 border-black bg-background px-3 py-2 text-sm text-foreground shadow-sm transition-all placeholder:text-muted-foreground focus-visible:outline-hidden focus-visible:shadow-md"
                  .space-y-1
                    = render LabelComponent.new(text: "Reference placeholder", for_id: "reference_placeholder")
                    = text_field_tag :reference_placeholder,
                      nil,
                      placeholder: "Select reference",
                      class: "flex h-10 w-full rounded border-2 border-black bg-background px-3 py-2 text-sm text-foreground shadow-sm transition-all placeholder:text-muted-foreground focus-visible:outline-hidden focus-visible:shadow-md"
              %label.inline-flex.items-center.gap-2.text-sm
                = check_box_tag :label, "1", true, class: "h-4 w-4 rounded border-2 border-black"
                %span Show label
              .flex.flex-wrap.gap-4
                %label.inline-flex.items-center.gap-2.text-sm
                  = check_box_tag :display_compact, "1", false, class: "h-4 w-4 rounded border-2 border-black"
                  %span Compact display
                %label.inline-flex.items-center.gap-2.text-sm
                  = check_box_tag :display_readonly, "1", false, class: "h-4 w-4 rounded border-2 border-black"
                  %span Read-only display

              .rounded.border-2.border-black.bg-muted.p-3{ data: { edit_affordance_builder_target: "collection" } }
                .mb-3.font-head.text-sm Collection options
                .grid.gap-3.md:grid-cols-3
                  .space-y-1
                    = render LabelComponent.new(text: "Presentation", for_id: "collection_presentation")
                    = select_tag :collection_presentation,
                      options_for_select(%w[list table cards]),
                      class: "flex h-10 w-full rounded border-2 border-black bg-background px-3 py-2 text-sm text-foreground shadow-sm transition-all focus-visible:outline-hidden focus-visible:shadow-md"
                  .space-y-1
                    = render LabelComponent.new(text: "Creation", for_id: "collection_creation")
                    = select_tag :collection_creation,
                      options_for_select(@collection_creation_options),
                      class: "flex h-10 w-full rounded border-2 border-black bg-background px-3 py-2 text-sm text-foreground shadow-sm transition-all focus-visible:outline-hidden focus-visible:shadow-md"
                  .space-y-1
                    = render LabelComponent.new(text: "Item screen", for_id: "collection_item_screen")
                    = select_tag :collection_item_screen,
                      options_for_select([["None", ""]] + @screen_ids.map { |screen_id| [screen_id, screen_id] }),
                      class: "flex h-10 w-full rounded border-2 border-black bg-background px-3 py-2 text-sm text-foreground shadow-sm transition-all placeholder:text-muted-foreground focus-visible:outline-hidden focus-visible:shadow-md"
                  .space-y-1
                    = render LabelComponent.new(text: "Delete", for_id: "collection_delete")
                    = select_tag :collection_delete,
                      options_for_select(%w[disabled enabled]),
                      class: "flex h-10 w-full rounded border-2 border-black bg-background px-3 py-2 text-sm text-foreground shadow-sm transition-all focus-visible:outline-hidden focus-visible:shadow-md"
                  .space-y-1
                    = render LabelComponent.new(text: "Reorder", for_id: "collection_reorder")
                    = select_tag :collection_reorder,
                      options_for_select(%w[disabled enabled]),
                      class: "flex h-10 w-full rounded border-2 border-black bg-background px-3 py-2 text-sm text-foreground shadow-sm transition-all focus-visible:outline-hidden focus-visible:shadow-md"
                .mt-3.grid.gap-3.md:grid-cols-2
                  .grid.gap-2.md:grid-cols-2
                    .space-y-1
                      = render LabelComponent.new(text: "Title binding", for_id: "item_title_kind")
                      = select_tag :item_title_kind,
                        options_for_select(@collection_binding_options, "property"),
                        class: "flex h-10 w-full rounded border-2 border-black bg-background px-3 py-2 text-sm text-foreground shadow-sm transition-all focus-visible:outline-hidden focus-visible:shadow-md"
                    .space-y-1
                      = render LabelComponent.new(text: "Title property", for_id: "item_title_name")
                      = text_field_tag :item_title_name,
                        "name",
                        class: "flex h-10 w-full rounded border-2 border-black bg-background px-3 py-2 text-sm text-foreground shadow-sm transition-all focus-visible:outline-hidden focus-visible:shadow-md"
                    .space-y-1
                      = render LabelComponent.new(text: "Title reference schema", for_id: "item_title_schema_key")
                      = text_field_tag :item_title_schema_key,
                        nil,
                        placeholder: "person",
                        class: "flex h-10 w-full rounded border-2 border-black bg-background px-3 py-2 text-sm text-foreground shadow-sm transition-all placeholder:text-muted-foreground focus-visible:outline-hidden focus-visible:shadow-md"
                    .space-y-1
                      = render LabelComponent.new(text: "Title reference schema property", for_id: "item_title_schema_key_property")
                      = text_field_tag :item_title_schema_key_property,
                        "kind",
                        class: "flex h-10 w-full rounded border-2 border-black bg-background px-3 py-2 text-sm text-foreground shadow-sm transition-all focus-visible:outline-hidden focus-visible:shadow-md"
                    .space-y-1
                      = render LabelComponent.new(text: "Title reference key property", for_id: "item_title_key_property")
                      = text_field_tag :item_title_key_property,
                        "key",
                        class: "flex h-10 w-full rounded border-2 border-black bg-background px-3 py-2 text-sm text-foreground shadow-sm transition-all focus-visible:outline-hidden focus-visible:shadow-md"
                    .space-y-1
                      = render LabelComponent.new(text: "Title reference index key", for_id: "item_title_index_key")
                      = text_field_tag :item_title_index_key,
                        "document_key",
                        class: "flex h-10 w-full rounded border-2 border-black bg-background px-3 py-2 text-sm text-foreground shadow-sm transition-all focus-visible:outline-hidden focus-visible:shadow-md"
                  .grid.gap-2.md:grid-cols-2
                    .space-y-1
                      = render LabelComponent.new(text: "Subtitle binding", for_id: "item_subtitle_kind")
                      = select_tag :item_subtitle_kind,
                        options_for_select(@collection_binding_options, "value_label"),
                        class: "flex h-10 w-full rounded border-2 border-black bg-background px-3 py-2 text-sm text-foreground shadow-sm transition-all focus-visible:outline-hidden focus-visible:shadow-md"
                    .space-y-1
                      = render LabelComponent.new(text: "Subtitle property", for_id: "item_subtitle_name")
                      = text_field_tag :item_subtitle_name,
                        nil,
                        placeholder: "quantity",
                        class: "flex h-10 w-full rounded border-2 border-black bg-background px-3 py-2 text-sm text-foreground shadow-sm transition-all placeholder:text-muted-foreground focus-visible:outline-hidden focus-visible:shadow-md"
                    .space-y-1
                      = render LabelComponent.new(text: "Subtitle reference schema", for_id: "item_subtitle_schema_key")
                      = text_field_tag :item_subtitle_schema_key,
                        nil,
                        placeholder: "person",
                        class: "flex h-10 w-full rounded border-2 border-black bg-background px-3 py-2 text-sm text-foreground shadow-sm transition-all placeholder:text-muted-foreground focus-visible:outline-hidden focus-visible:shadow-md"
                    .space-y-1
                      = render LabelComponent.new(text: "Subtitle reference schema property", for_id: "item_subtitle_schema_key_property")
                      = text_field_tag :item_subtitle_schema_key_property,
                        "kind",
                        class: "flex h-10 w-full rounded border-2 border-black bg-background px-3 py-2 text-sm text-foreground shadow-sm transition-all focus-visible:outline-hidden focus-visible:shadow-md"
                    .space-y-1
                      = render LabelComponent.new(text: "Subtitle reference key property", for_id: "item_subtitle_key_property")
                      = text_field_tag :item_subtitle_key_property,
                        "key",
                        class: "flex h-10 w-full rounded border-2 border-black bg-background px-3 py-2 text-sm text-foreground shadow-sm transition-all focus-visible:outline-hidden focus-visible:shadow-md"
                    .space-y-1
                      = render LabelComponent.new(text: "Subtitle reference index key", for_id: "item_subtitle_index_key")
                      = text_field_tag :item_subtitle_index_key,
                        "document_key",
                        class: "flex h-10 w-full rounded border-2 border-black bg-background px-3 py-2 text-sm text-foreground shadow-sm transition-all focus-visible:outline-hidden focus-visible:shadow-md"
              .rounded.border-2.border-black.bg-muted.p-3.text-sm.text-muted-foreground{ data: { edit_affordance_builder_target: "collectionNote" } }
                Collection policy: array fields only.

              = submit_tag "Add field",
                disabled: @rows.empty?,
                class: "font-head inline-flex h-10 items-center justify-center rounded border-2 border-black bg-primary px-4 py-2 font-medium text-primary-foreground shadow-md transition-all hover:translate-y-1 hover:shadow-none#{@rows.empty? ? " cursor-not-allowed opacity-50" : ""}"

      = render CardComponent.new(html_options: { class: "w-full" }) do
        = render CardContentComponent.new do
          .grid.gap-6.lg:grid-cols-2
            .space-y-4
              = render TypographyComponent.new(as: :h3, text: "Add navigation")
              = form_with url: add_navigation_draft_edit_affordance_builder_path(@draft, builder_screen_params),
                method: :patch,
                data: { turbo_frame: "main_content" },
                class: "space-y-4" do
                .grid.gap-3.md:grid-cols-2
                  .space-y-1
                    = render LabelComponent.new(text: "Target screen", for_id: "target_screen")
                    = select_tag :target_screen,
                      options_for_select(@screen_ids.map { |screen_id| [screen_id, screen_id] }),
                      class: "flex h-10 w-full rounded border-2 border-black bg-background px-3 py-2 text-sm text-foreground shadow-sm transition-all focus-visible:outline-hidden focus-visible:shadow-md"
                  .space-y-1
                    = render LabelComponent.new(text: "Row", for_id: "navigation_row_index")
                    = select_tag :row_index,
                      options_for_select(row_options, @rows.empty? ? nil : @rows.length - 1),
                      id: "navigation_row_index",
                      class: "flex h-10 w-full rounded border-2 border-black bg-background px-3 py-2 text-sm text-foreground shadow-sm transition-all focus-visible:outline-hidden focus-visible:shadow-md"
                  .space-y-1
                    = render LabelComponent.new(text: "Label", for_id: "navigation_label")
                    = text_field_tag :navigation_label,
                      nil,
                      class: "flex h-10 w-full rounded border-2 border-black bg-background px-3 py-2 text-sm text-foreground shadow-sm transition-all focus-visible:outline-hidden focus-visible:shadow-md"
                  .space-y-1
                    = render LabelComponent.new(text: "Span", for_id: "navigation_span")
                    = number_field_tag :navigation_span,
                      3,
                      min: 1,
                      max: 12,
                      class: "flex h-10 w-full rounded border-2 border-black bg-background px-3 py-2 text-sm text-foreground shadow-sm transition-all focus-visible:outline-hidden focus-visible:shadow-md"
                = submit_tag "Add navigation",
                  disabled: @rows.empty? || @screen_ids.empty?,
                  class: "font-head inline-flex h-10 items-center justify-center rounded border-2 border-black bg-primary px-4 py-2 font-medium text-primary-foreground shadow-md transition-all hover:translate-y-1 hover:shadow-none#{@rows.empty? || @screen_ids.empty? ? " cursor-not-allowed opacity-50" : ""}"

            .space-y-4
              = render TypographyComponent.new(as: :h3, text: "Add commit")
              = form_with url: add_commit_draft_edit_affordance_builder_path(@draft, builder_screen_params),
                method: :patch,
                data: { turbo_frame: "main_content" },
                class: "space-y-4" do
                .grid.gap-3.md:grid-cols-2
                  .space-y-1
                    = render LabelComponent.new(text: "Row", for_id: "commit_row_index")
                    = select_tag :row_index,
                      options_for_select(row_options, @rows.empty? ? nil : @rows.length - 1),
                      id: "commit_row_index",
                      class: "flex h-10 w-full rounded border-2 border-black bg-background px-3 py-2 text-sm text-foreground shadow-sm transition-all focus-visible:outline-hidden focus-visible:shadow-md"
                  .space-y-1
                    = render LabelComponent.new(text: "Span", for_id: "commit_span")
                    = number_field_tag :commit_span,
                      3,
                      min: 1,
                      max: 12,
                      class: "flex h-10 w-full rounded border-2 border-black bg-background px-3 py-2 text-sm text-foreground shadow-sm transition-all focus-visible:outline-hidden focus-visible:shadow-md"
                  .space-y-1
                    = render LabelComponent.new(text: "Commit mode", for_id: "commit_mode")
                    = select_tag :commit_mode,
                      options_for_select([["Review screen", "review_screen"], ["Immediate", "immediate"]]),
                      class: "flex h-10 w-full rounded border-2 border-black bg-background px-3 py-2 text-sm text-foreground shadow-sm transition-all focus-visible:outline-hidden focus-visible:shadow-md"
                  .space-y-1
                    = render LabelComponent.new(text: "Message mode", for_id: "message_mode")
                    = select_tag :message_mode,
                      options_for_select([["Hidden", "hidden"], ["Inline optional", "inline_optional"], ["Inline required", "inline_required"]], "inline_optional"),
                      class: "flex h-10 w-full rounded border-2 border-black bg-background px-3 py-2 text-sm text-foreground shadow-sm transition-all focus-visible:outline-hidden focus-visible:shadow-md"
                = submit_tag "Add commit",
                  disabled: @rows.empty?,
                  class: "font-head inline-flex h-10 items-center justify-center rounded border-2 border-black bg-primary px-4 py-2 font-medium text-primary-foreground shadow-md transition-all hover:translate-y-1 hover:shadow-none#{@rows.empty? ? " cursor-not-allowed opacity-50" : ""}"

      = render CardComponent.new(html_options: { class: "w-full" }) do
        = render CardContentComponent.new do
          = render TypographyComponent.new(as: :h3, text: "Current main screen", html_options: { class: "mb-3" })
          - if @rows.empty?
            = render AlertComponent.new do
              No fields yet.
          - else
            %ol.space-y-2
              - @rows.each_with_index do |row, row_index|
                %li.rounded.border-2.border-black.bg-card.p-3.text-sm.shadow-sm
                  .flex.items-center.justify-between.gap-3
                    = link_to "Row #{row_index + 1}",
                      row_draft_edit_affordance_builder_path(@draft, builder_path_params.call(row_index: row_index)),
                      data: { turbo_frame: "main_content" },
                      class: "font-head underline decoration-2 underline-offset-4"
                    .flex.flex-wrap.items-center.justify-end.gap-2
                      - if row_index.positive?
                        = button_to "Up",
                          move_row_draft_edit_affordance_builder_path(@draft, builder_path_params.call(row_index: row_index)),
                          method: :patch,
                          params: { direction: "up" },
                          form: { data: { turbo_frame: "main_content" } },
                          class: "font-head inline-flex h-8 items-center justify-center rounded border-2 border-black bg-background px-3 text-xs font-medium text-foreground shadow-sm transition-all hover:translate-y-1 hover:shadow-none"
                      - if row_index < @rows.length - 1
                        = button_to "Down",
                          move_row_draft_edit_affordance_builder_path(@draft, builder_path_params.call(row_index: row_index)),
                          method: :patch,
                          params: { direction: "down" },
                          form: { data: { turbo_frame: "main_content" } },
                          class: "font-head inline-flex h-8 items-center justify-center rounded border-2 border-black bg-background px-3 text-xs font-medium text-foreground shadow-sm transition-all hover:translate-y-1 hover:shadow-none"
                      .text-xs.text-muted-foreground= pluralize(row.length, "cell")
                  - if row.empty?
                    .mt-2.text-muted-foreground Empty row
                  - else
                    .mt-3.space-y-2
                      - row.each_with_index do |cell, cell_index|
                        .grid.gap-3.rounded.border-2.border-black.bg-background.p-3.md:grid-cols-3
                          .md:col-span-2
                            .font-mono.text-xs.text-muted-foreground= cell.dig("binding", "ptr") || cell["kind"]
                            .mt-1
                              %span.font-head Span
                              = cell["span"] || @selected_screen&.fetch("default_span", 3)
                            - if cell["collection"].is_a?(Hash)
                              .mt-2.text-xs.text-muted-foreground
                                Collection:
                                = [cell.dig("collection", "presentation"), cell.dig("collection", "creation"), "delete #{cell.dig('collection', 'delete')}", "reorder #{cell.dig('collection', 'reorder')}"].compact.join(", ")
                          .text-sm.text-muted-foreground
                            - if cell["help"].present?
                              = cell["help"]
                            - else
                              No help text.
                            .mt-3
                              = link_to "Open field",
                                cell_draft_edit_affordance_builder_path(@draft, builder_path_params.call(row_index: row_index, cell_index: cell_index)),
                                data: { turbo_frame: "main_content" },
                                class: "font-head inline-flex h-8 items-center justify-center rounded border-2 border-black bg-background px-3 text-xs font-medium text-foreground shadow-sm transition-all hover:translate-y-1 hover:shadow-none"

    - elsif @tab == "row"
      = render CardComponent.new(html_options: { class: "w-full" }) do
        = render CardContentComponent.new do
          .space-y-4
            .flex.flex-wrap.items-center.justify-between.gap-3
              .space-y-1
                = render TypographyComponent.new(as: :h3, text: "Row #{@row_index + 1}")
                = render TypographyComponent.new(as: :muted, text: pluralize(@row.length, "field"))
              .flex.flex-wrap.gap-2
                = link_to "Back to builder",
                  draft_edit_affordance_builder_path(@draft, builder_path_params.call(tab: "builder")),
                  data: { turbo_frame: "main_content" },
                  class: "font-head inline-flex h-9 items-center justify-center rounded border-2 border-black bg-background px-3 text-sm font-medium text-foreground shadow-sm transition-all hover:translate-y-1 hover:shadow-none"
                = button_to "Delete row",
                  row_draft_edit_affordance_builder_path(@draft, builder_path_params.call(row_index: @row_index)),
                  method: :delete,
                  form: { data: { turbo_frame: "main_content" } },
                  class: "font-head inline-flex h-9 items-center justify-center rounded border-2 border-black bg-destructive px-3 text-sm font-medium text-destructive-foreground shadow-sm transition-all hover:translate-y-1 hover:shadow-none"

            - if @row.empty?
              = render AlertComponent.new do
                Empty row.
            - else
              %ol.space-y-2
                - @row.each_with_index do |cell, cell_index|
                  %li.rounded.border-2.border-black.bg-card.p-3.text-sm.shadow-sm
                    .flex.flex-wrap.items-start.justify-between.gap-3
                      .space-y-1
                        .font-head Field #{cell_index + 1}
                        .font-mono.text-xs.text-muted-foreground= cell.dig("binding", "ptr") || cell["kind"]
                        .text-xs.text-muted-foreground
                          Span #{cell["span"] || @selected_screen&.fetch("default_span", 3)}
                      .flex.flex-wrap.gap-2
                        - if cell_index.positive?
                          = button_to "Left",
                            move_cell_draft_edit_affordance_builder_path(@draft, builder_path_params.call(row_index: @row_index, cell_index: cell_index)),
                            method: :patch,
                            params: { direction: "left" },
                            form: { data: { turbo_frame: "main_content" } },
                            class: "font-head inline-flex h-8 items-center justify-center rounded border-2 border-black bg-background px-3 text-xs font-medium text-foreground shadow-sm transition-all hover:translate-y-1 hover:shadow-none"
                        - if cell_index < @row.length - 1
                          = button_to "Right",
                            move_cell_draft_edit_affordance_builder_path(@draft, builder_path_params.call(row_index: @row_index, cell_index: cell_index)),
                            method: :patch,
                            params: { direction: "right" },
                            form: { data: { turbo_frame: "main_content" } },
                            class: "font-head inline-flex h-8 items-center justify-center rounded border-2 border-black bg-background px-3 text-xs font-medium text-foreground shadow-sm transition-all hover:translate-y-1 hover:shadow-none"
                        = link_to "Open",
                          cell_draft_edit_affordance_builder_path(@draft, builder_path_params.call(row_index: @row_index, cell_index: cell_index)),
                          data: { turbo_frame: "main_content" },
                          class: "font-head inline-flex h-8 items-center justify-center rounded border-2 border-black bg-background px-3 text-xs font-medium text-foreground shadow-sm transition-all hover:translate-y-1 hover:shadow-none"
                        = button_to "Delete",
                          cell_draft_edit_affordance_builder_path(@draft, builder_path_params.call(row_index: @row_index, cell_index: cell_index)),
                          method: :delete,
                          form: { data: { turbo_frame: "main_content" } },
                          class: "font-head inline-flex h-8 items-center justify-center rounded border-2 border-black bg-destructive px-3 text-xs font-medium text-destructive-foreground shadow-sm transition-all hover:translate-y-1 hover:shadow-none"

    - elsif @tab == "cell"
      = render CardComponent.new(html_options: { class: "w-full" }) do
        = render CardContentComponent.new do
          .space-y-4
            .flex.flex-wrap.items-start.justify-between.gap-3
              .space-y-1
                = render TypographyComponent.new(as: :h3, text: "Field #{@cell_index + 1}")
                = render TypographyComponent.new(as: :muted, text: "Row #{@row_index + 1}")
              .flex.flex-wrap.gap-2
                = link_to "Back to row",
                  row_draft_edit_affordance_builder_path(@draft, builder_path_params.call(row_index: @row_index)),
                  data: { turbo_frame: "main_content" },
                  class: "font-head inline-flex h-9 items-center justify-center rounded border-2 border-black bg-background px-3 text-sm font-medium text-foreground shadow-sm transition-all hover:translate-y-1 hover:shadow-none"
                = button_to "Delete field",
                  cell_draft_edit_affordance_builder_path(@draft, builder_path_params.call(row_index: @row_index, cell_index: @cell_index)),
                  method: :delete,
                  form: { data: { turbo_frame: "main_content" } },
                  class: "font-head inline-flex h-9 items-center justify-center rounded border-2 border-black bg-destructive px-3 text-sm font-medium text-destructive-foreground shadow-sm transition-all hover:translate-y-1 hover:shadow-none"
            - if @cell.key?("binding")
              - current_collection = @cell["collection"].is_a?(Hash) ? @cell["collection"] : {}
              - current_reference = @cell["reference"].is_a?(Hash) ? @cell["reference"] : {}
              - current_display = @cell["display"].is_a?(Hash) ? @cell["display"] : {}
              = form_with url: cell_draft_edit_affordance_builder_path(@draft, builder_path_params.call(row_index: @row_index, cell_index: @cell_index)),
                method: :patch,
                data: { turbo_frame: "main_content", controller: "edit-affordance-builder" },
                class: "space-y-4" do
                .grid.gap-3.md:grid-cols-3
                  .space-y-1
                    = render LabelComponent.new(text: "Schema path", for_id: "ptr")
                    = select_tag :ptr,
                      options_for_select(@field_entries.map { |entry| ["#{entry.label} (#{entry.ptr})", entry.ptr, { "data-widget": entry.widget, "data-array": entry.array? ? "true" : "false" }] }, @cell.dig("binding", "ptr")),
                      data: { edit_affordance_builder_target: "path", action: "edit-affordance-builder#sync" },
                      class: "flex h-10 w-full rounded border-2 border-black bg-background px-3 py-2 text-sm text-foreground shadow-sm transition-all focus-visible:outline-hidden focus-visible:shadow-md"
                  .space-y-1
                    = render LabelComponent.new(text: "Widget", for_id: "widget")
                    = select_tag :widget,
                      options_for_select(@widget_options, @cell["widget"] || "auto"),
                      class: "flex h-10 w-full rounded border-2 border-black bg-background px-3 py-2 text-sm text-foreground shadow-sm transition-all focus-visible:outline-hidden focus-visible:shadow-md"
                  .space-y-1
                    = render LabelComponent.new(text: "Span", for_id: "span")
                    = number_field_tag :span,
                      @cell["span"] || @selected_screen&.fetch("default_span", 3),
                      min: 1,
                      max: 12,
                      class: "flex h-10 w-full rounded border-2 border-black bg-background px-3 py-2 text-sm text-foreground shadow-sm transition-all focus-visible:outline-hidden focus-visible:shadow-md"
                  .space-y-1
                    = render LabelComponent.new(text: "Help", for_id: "help")
                    = text_field_tag :help,
                      @cell["help"],
                      class: "flex h-10 w-full rounded border-2 border-black bg-background px-3 py-2 text-sm text-foreground shadow-sm transition-all focus-visible:outline-hidden focus-visible:shadow-md"
                  .space-y-1
                    = render LabelComponent.new(text: "Placeholder", for_id: "placeholder")
                    = text_field_tag :placeholder,
                      @cell["placeholder"],
                      class: "flex h-10 w-full rounded border-2 border-black bg-background px-3 py-2 text-sm text-foreground shadow-sm transition-all focus-visible:outline-hidden focus-visible:shadow-md"
                %label.inline-flex.items-center.gap-2.text-sm
                  = check_box_tag :label, "1", @cell.fetch("label", true), class: "h-4 w-4 rounded border-2 border-black"
                  %span Show label
                .flex.flex-wrap.gap-4
                  %label.inline-flex.items-center.gap-2.text-sm
                    = check_box_tag :display_compact, "1", current_display["compact"] == true, class: "h-4 w-4 rounded border-2 border-black"
                    %span Compact display
                  %label.inline-flex.items-center.gap-2.text-sm
                    = check_box_tag :display_readonly, "1", current_display["readonly"] == true, class: "h-4 w-4 rounded border-2 border-black"
                    %span Read-only display

                .rounded.border-2.border-black.bg-muted.p-3
                  .mb-3.font-head.text-sm Reference options
                  .grid.gap-3.md:grid-cols-3
                    .space-y-1
                      = render LabelComponent.new(text: "Schema key", for_id: "reference_schema_key")
                      = text_field_tag :reference_schema_key,
                        current_reference["schema_key"],
                        placeholder: "person",
                        class: "flex h-10 w-full rounded border-2 border-black bg-background px-3 py-2 text-sm text-foreground shadow-sm transition-all placeholder:text-muted-foreground focus-visible:outline-hidden focus-visible:shadow-md"
                    .space-y-1
                      = render LabelComponent.new(text: "Index type", for_id: "reference_index_type")
                      = text_field_tag :reference_index_type,
                        current_reference["index_type"] || "identity",
                        class: "flex h-10 w-full rounded border-2 border-black bg-background px-3 py-2 text-sm text-foreground shadow-sm transition-all focus-visible:outline-hidden focus-visible:shadow-md"
                    .space-y-1
                      = render LabelComponent.new(text: "Index key", for_id: "reference_index_key")
                      = text_field_tag :reference_index_key,
                        current_reference["index_key"] || "document_key",
                        class: "flex h-10 w-full rounded border-2 border-black bg-background px-3 py-2 text-sm text-foreground shadow-sm transition-all focus-visible:outline-hidden focus-visible:shadow-md"
                    .space-y-1
                      = render LabelComponent.new(text: "Schema key from", for_id: "reference_schema_key_from")
                      = text_field_tag :reference_schema_key_from,
                        current_reference["schema_key_from"],
                        placeholder: "/kind",
                        class: "flex h-10 w-full rounded border-2 border-black bg-background px-3 py-2 text-sm text-foreground shadow-sm transition-all placeholder:text-muted-foreground focus-visible:outline-hidden focus-visible:shadow-md"
                    .space-y-1
                      = render LabelComponent.new(text: "Reference placeholder", for_id: "reference_placeholder")
                      = text_field_tag :reference_placeholder,
                        current_reference["placeholder"],
                        placeholder: "Select reference",
                        class: "flex h-10 w-full rounded border-2 border-black bg-background px-3 py-2 text-sm text-foreground shadow-sm transition-all placeholder:text-muted-foreground focus-visible:outline-hidden focus-visible:shadow-md"

                .rounded.border-2.border-black.bg-muted.p-3{ data: { edit_affordance_builder_target: "collection" } }
                  .mb-3.font-head.text-sm Collection options
                  .grid.gap-3.md:grid-cols-3
                    .space-y-1
                      = render LabelComponent.new(text: "Presentation", for_id: "collection_presentation")
                      = select_tag :collection_presentation,
                        options_for_select(%w[list table cards], current_collection["presentation"]),
                        class: "flex h-10 w-full rounded border-2 border-black bg-background px-3 py-2 text-sm text-foreground shadow-sm transition-all focus-visible:outline-hidden focus-visible:shadow-md"
                    .space-y-1
                      = render LabelComponent.new(text: "Creation", for_id: "collection_creation")
                      = select_tag :collection_creation,
                        options_for_select(@collection_creation_options, current_collection["creation"]),
                        class: "flex h-10 w-full rounded border-2 border-black bg-background px-3 py-2 text-sm text-foreground shadow-sm transition-all focus-visible:outline-hidden focus-visible:shadow-md"
                    .space-y-1
                      = render LabelComponent.new(text: "Item screen", for_id: "collection_item_screen")
                      = select_tag :collection_item_screen,
                        options_for_select([["None", ""]] + @screen_ids.map { |screen_id| [screen_id, screen_id] }, current_collection["item_screen"]),
                        class: "flex h-10 w-full rounded border-2 border-black bg-background px-3 py-2 text-sm text-foreground shadow-sm transition-all focus-visible:outline-hidden focus-visible:shadow-md"
                    .space-y-1
                      = render LabelComponent.new(text: "Delete", for_id: "collection_delete")
                      = select_tag :collection_delete,
                        options_for_select(%w[disabled enabled], current_collection["delete"]),
                        class: "flex h-10 w-full rounded border-2 border-black bg-background px-3 py-2 text-sm text-foreground shadow-sm transition-all focus-visible:outline-hidden focus-visible:shadow-md"
                    .space-y-1
                      = render LabelComponent.new(text: "Reorder", for_id: "collection_reorder")
                      = select_tag :collection_reorder,
                        options_for_select(%w[disabled enabled], current_collection["reorder"]),
                        class: "flex h-10 w-full rounded border-2 border-black bg-background px-3 py-2 text-sm text-foreground shadow-sm transition-all focus-visible:outline-hidden focus-visible:shadow-md"
                  .mt-3.grid.gap-3.md:grid-cols-2
                    .grid.gap-2.md:grid-cols-2
                      .space-y-1
                        = render LabelComponent.new(text: "Title binding", for_id: "item_title_kind")
                        = select_tag :item_title_kind,
                          options_for_select(@collection_binding_options, current_collection.dig("item_title", "kind") || "property"),
                          class: "flex h-10 w-full rounded border-2 border-black bg-background px-3 py-2 text-sm text-foreground shadow-sm transition-all focus-visible:outline-hidden focus-visible:shadow-md"
                      .space-y-1
                        = render LabelComponent.new(text: "Title property", for_id: "item_title_name")
                        = text_field_tag :item_title_name,
                          current_collection.dig("item_title", "name") || "name",

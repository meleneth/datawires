= render DocumentNavRibbonComponent.new(document: document, draft: draft, path: @path, turbo_frame: "editor")

.space-y-4
  .flex.items-center.justify-between
    %h3.text-lg.font-semibold.text-ink= "Document: #{@path}"

    = link_to "Commit…", new_draft_commit_path(draft), data: { turbo_frame: "main_content" }, class: "inline-flex items-center rounded-lg border border-ls5-blue-5 bg-ls5-blue-4 px-3 py-2 font-medium text-ink-inverse hover:bg-ls5-blue-5"

  - if @value.is_a?(Hash)
    = render "document_object_editor", draft: draft

  - elsif @value.is_a?(Array)
    = render "document_array_editor"

  - else
    = render "document_scalar_editor", draft: draft

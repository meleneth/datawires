<%= turbo_stream.update "review" do %>
  <%= render "drafts/review", draft: @draft %>
<% end %>

<%= turbo_stream.update "ribbon" do %>
  <% if @draft.schema_document? %>
    <%= render Navigation::Schemas::NavRibbonComponent.new(
      domain: @domain,
      document: @document,
      draft: @draft,
      path: @path,
      turbo_frame: "editor"
    ) %>
  <% else %>
    <%= render "drafts/ribbon",
      domain: @domain,
      document: @document,
      draft: @draft,
      ptr: @path.to_s %>
  <% end %>
<% end %>

<%= turbo_stream.update "editor" do %>
  <% if @draft.schema_document? %>
    <%= render "drafts/schema_editor",
      domain: @domain,
      document: @document,
      draft: @draft,
      path: @path %>
  <% else %>
    <%= render "drafts/document_editor",
      domain: @domain,
      document: @document,
      draft: @draft,
      path: @path %>
  <% end %>
<% end %>

.space-y-3
  - Array(@property_rows).each do |row|
    .rounded-lg.border.border-ls5-violet-3.bg-white.p-3
      .flex.items-start.justify-between.gap-4
        .min-w-0.flex-1
          .font-medium.text-ink= row.name
          .text-sm.text-ls5-violet-6= row.type

          - if row.required?
            .mt-1.text-xs.text-ls5-violet-5 required
          - if row.scalar?
            .mt-3
              = render DocumentScalarFieldComponent.new(row: row)
          - elsif row.composite?
            .mt-2.text-xs.text-ls5-violet-5= row.value_label

        - if row.composite?
          = link_to "Open", draft_path(draft, path: row.path.to_s), data: { turbo_frame: "editor", turbo_action: "advance" }, class: "rounded-lg px-3 py-2 text-sm font-medium text-ls5-blue-4 hover:bg-ls5-violet-1"

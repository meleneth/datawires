.space-y-4
  - Array(@editor_rows).each do |editor_row|
    .grid.grid-cols-12.gap-4
      - editor_row.cells.each do |cell|
        - span = cell.span || 12
        %div{ class: "col-span-#{span}" }
          - if cell.field?
            - row = cell.projection_row
            .rounded-lg.border.border-ls5-violet-3.bg-white.p-3
              .flex.items-start.justify-between.gap-4
                .min-w-0.flex-1
                  - if cell.label
                    .font-medium.text-ink= row.name

                  .text-sm.text-ls5-violet-6= row.type

                  - if row.required?
                    .mt-1.text-xs.text-ls5-violet-5 required

                  - if row.scalar?
                    .mt-3
                      = render DocumentScalarFieldComponent.new(row: row, widget: cell.widget,  show_label: cell.label)

                  - elsif row.composite?
                    .mt-2.text-xs.text-ls5-violet-5= row.value_label

                - if row.composite?
                  = link_to "Open",
                    draft_path(draft, path: row.path.to_s, edit_affordance_id: params[:edit_affordance_id]),
                    data: { turbo_frame: "editor", turbo_action: "advance" },
                    class: "rounded-lg px-3 py-2 text-sm font-medium text-ls5-blue-4 hover:bg-ls5-violet-1"

          - elsif cell.commit?
            .rounded-lg.border.border-ls5-blue-3.bg-white.p-4
              = form_with url: draft_commit_path(draft), method: :post, class: "space-y-3" do |form|
                = hidden_field_tag :edit_affordance_id, params[:edit_affordance_id]

                - if cell.message_mode != "hidden"
                  .space-y-1
                    = form.label :message, "Commit message", class: "block text-sm font-medium text-ink"
                    = form.text_field :message,
                      required: (cell.message_mode == "inline_required"),
                      class: "w-full rounded-md border border-ls5-violet-2 px-3 py-2"

                = form.submit "Publish",
                  class: "inline-flex items-center rounded-lg bg-ls5-blue-4 px-3 py-2 font-medium text-ink-inverse hover:bg-ls5-blue-5"

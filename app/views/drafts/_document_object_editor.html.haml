.space-y-3
  - Array(@property_rows).each do |row|
    .rounded-lg.border.border-ls5-violet-3.bg-white.p-3
      .flex.items-start.justify-between.gap-4
        .min-w-0.flex-1
          .font-medium.text-ink= row.name
          .text-sm.text-ls5-violet-6= row.type

          - if row.required?
            .mt-1.text-xs.text-ls5-violet-5 required

          - if row.scalar?
            = form_with url: patch_ptr_draft_path(draft), method: :patch, format: :turbo_stream, data: { turbo_frame: "editor", controller: "autosave" }, class: "mt-3" do
              = hidden_field_tag :ptr, row.ptr

              - case row.input_kind
              - when :checkbox
                %label.flex.items-center.gap-2
                  = check_box_tag :value, "true", row.field_value, data: { action: "change->autosave#submit blur->autosave#submit" }
                  %span.text-sm.text-ink Set
              - when :number
                = number_field_tag :value, row.field_value, class: "w-full rounded-md border border-ls5-violet-3 bg-white px-3 py-2 text-ink", data: { action: "input->autosave#queue blur->autosave#submit" }
              - else
                = text_field_tag :value, row.field_value, class: "w-full rounded-md border border-ls5-violet-3 bg-white px-3 py-2 text-ink", data: { action: "input->autosave#queue blur->autosave#submit" }

          - elsif row.composite?
            .mt-2.text-xs.text-ls5-violet-5= row.value_label

        - if row.composite?
          = link_to "Open", draft_path(draft, path: row.path.to_s), data: { turbo_frame: "editor", turbo_action: "advance" }, class: "rounded-lg px-3 py-2 text-sm font-medium text-ls5-blue-4 hover:bg-ls5-violet-1"

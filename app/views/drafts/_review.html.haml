= render CardComponent.new(html_options: { class: "w-full" }) do
  = render CardContentComponent.new do
    .space-y-4
      .flex.items-center.justify-between
        = render TypographyComponent.new(as: :h3, text: "Changes")
        = render BadgeComponent.new(variant: :outline) do
          = pluralize(diff_rows.size, "change")

      - if diff_rows.empty?
        = render AlertComponent.new do
          No changes.
      - else
        .overflow-x-auto
          = render TableComponent.new(html_options: { class: "min-w-full text-sm" }) do
            = render TableHeaderComponent.new do
              = render TableRowComponent.new do
                = render TableHeadComponent.new do
                  Path
                = render TableHeadComponent.new do
                  Change
                = render TableHeadComponent.new do
                  Before
                = render TableHeadComponent.new do
                  After
            = render TableBodyComponent.new do
              - diff_rows.each do |row|
                - badge_variant = row.kind == :removed ? :destructive : (row.kind == :added ? :secondary : :outline)
                = render TableRowComponent.new(html_options: { class: "align-top" }) do
                  = render TableCellComponent.new(html_options: { class: "font-mono text-xs" }) do
                    = row.path
                  = render TableCellComponent.new do
                    = render BadgeComponent.new(variant: badge_variant) do
                      = row.kind.to_s.humanize
                  = render TableCellComponent.new(html_options: { class: "font-mono text-xs" }) do
                    - unless row.before.nil?
                      %pre.whitespace-pre-wrap.break-all= JSON.pretty_generate(row.before)
                  = render TableCellComponent.new(html_options: { class: "font-mono text-xs" }) do
                    - unless row.after.nil?
                      %pre.whitespace-pre-wrap.break-all= JSON.pretty_generate(row.after)

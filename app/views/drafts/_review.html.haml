= render Ui::CardComponent.new do
  .space-y-4
    .flex.items-center.justify-between
      %h3.text-lg.font-semibold.text-ink Changes
      .text-sm.text-slate-500= pluralize(diff_rows.size, "change")

    - if diff_rows.empty?
      .rounded-lg.bg-slate-50.p-4.text-sm.text-slate-600
        No changes.
    - else
      .overflow-x-auto
        %table.min-w-full.divide-y.divide-slate-200.text-sm
          %thead
            %tr
              %th.px-3.py-2.text-left.font-medium.text-slate-700 Path
              %th.px-3.py-2.text-left.font-medium.text-slate-700 Change
              %th.px-3.py-2.text-left.font-medium.text-slate-700 Before
              %th.px-3.py-2.text-left.font-medium.text-slate-700 After
          %tbody.divide-y.divide-slate-100
            - diff_rows.each do |row|
              - badge_classes = "bg-amber-100 text-amber-800"
              - badge_classes = "bg-green-100 text-green-800" if row.kind == :added
              - badge_classes = "bg-red-100 text-red-800" if row.kind == :removed
              %tr.align-top
                %td.px-3.py-2.font-mono.text-xs.text-slate-700= row.path
                %td.px-3.py-2
                  %span.inline-flex.rounded-full.px-2.py-1.text-xs.font-medium{ class: badge_classes }
                    = row.kind.to_s.humanize
                %td.px-3.py-2.font-mono.text-xs.text-slate-700
                  - unless row.before.nil?
                    %pre.whitespace-pre-wrap.break-all= JSON.pretty_generate(row.before)
                %td.px-3.py-2.font-mono.text-xs.text-slate-700
                  - unless row.after.nil?
                    %pre.whitespace-pre-wrap.break-all= JSON.pretty_generate(row.after)

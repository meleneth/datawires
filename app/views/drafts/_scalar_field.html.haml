- field_cursor = cursor

.space-y-1
  - if field.label
    = render LabelComponent.new(text: field_cursor.name.to_s.humanize, for_id: field_cursor.ptr.parameterize)

  - case field_cursor.input_kind
  - when :checkbox
    = form_with url: patch_ptr_draft_path(draft),
      method: :patch,
      data: { turbo_frame: "main_content" } do |form|
      = form.hidden_field :ptr, value: field_cursor.ptr
      = form.hidden_field :path, value: field_cursor.path.to_s
      = form.check_box :value, { checked: field_cursor.checkbox_value }, "true", "false"
  - when :select
    = form_with url: patch_ptr_draft_path(draft),
      method: :patch,
      data: { turbo_frame: "main_content" } do |form|
      = form.hidden_field :ptr, value: field_cursor.ptr
      = form.hidden_field :path, value: field_cursor.path.to_s
      = form.select :value,
        options_for_select(field_cursor.enum_values, field_cursor.field_value),
        {},
        class: "flex h-10 w-full rounded border-2 border-black bg-background px-3 py-2 text-sm text-foreground shadow-sm transition-all focus-visible:outline-hidden focus-visible:shadow-md"
  - else
    = form_with url: patch_ptr_draft_path(draft),
      method: :patch,
      data: { turbo_frame: "main_content" } do |form|
      = form.hidden_field :ptr, value: field_cursor.ptr
      = form.hidden_field :path, value: field_cursor.path.to_s
      = form.text_field :value,
        value: field_cursor.field_value,
        class: "flex h-10 w-full rounded border-2 border-black bg-background px-3 py-2 text-sm text-foreground shadow-sm transition-all placeholder:text-muted-foreground focus-visible:outline-hidden focus-visible:shadow-md"

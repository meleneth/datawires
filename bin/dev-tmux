#!/usr/bin/env bash
set -euo pipefail

SESSION="rails-dev"

tmux has-session -t "$SESSION" 2>/dev/null && tmux kill-session -t "$SESSION"

# Create session with current terminal dimensions (helps pane sizing behave)
COLS="$(tput cols)"
LINES="$(tput lines)"

tmux new-session -d -s "$SESSION" -x "$COLS" -y "$LINES"

# Split into top/bottom, then resize TOP to 4 lines
tmux split-window -v -t "$SESSION:0"
tmux resize-pane -t "$SESSION:0.0" -y 4

# Split the TOP pane left/right: left = bin/dev, right = coverage server
tmux split-window -h -t "$SESSION:0.0"

# Run processes
tmux send-keys -t "$SESSION:0.0" "bin/dev" C-m
tmux send-keys -t "$SESSION:0.1" "ruby -run -e httpd coverage -p 4000 -b 0.0.0.0" C-m
tmux send-keys -t "$SESSION:0.2" "tail -f log/development.log" C-m

tmux attach -t "$SESSION"

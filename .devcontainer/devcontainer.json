{
  "name": "datawires",
  "dockerComposeFile": "docker-compose.yml",
  "service": "app",
  "workspaceFolder": "/workspaces/datawires",
  "runServices": ["app", "db"],
  "remoteUser": "vscode",
  "updateRemoteUserUID": true,
  "forwardPorts": [3000],
  "postCreateCommand": "sh -lc 'sudo chown -R vscode:vscode /usr/local/bundle'",
  "customizations": {
    "vscode": {
      "extensions": [
        "Shopify.ruby-lsp"
      ]
    }
  }
}
